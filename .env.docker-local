# ============================================================================
# AI Code Review Platform - Docker Local Development Environment
# ============================================================================
# Copy this file to .env for local Docker development:
# cp .env.docker-local .env

# Database Configuration
POSTGRES_DB=ai_code_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j Configuration
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/neo4j123

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# Security Secrets
JWT_SECRET=dev_jwt_secret_key_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SECRET_KEY=dev_secret_key_32_chars_minimum
SESSION_SECRET=dev_session_secret_32_chars

# Application Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PROJECT_NAME="AI Code Review Platform"
API_V1_STR=/api/v1

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Performance Settings
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT=30
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Celery Configuration
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# Optional API Keys
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_WEBHOOK_SECRET=webhook_secret_dev

# OpenRouter API Configuration
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=anthropic/claude-3.5-sonnet

# LLM Service
LLM_ENABLED=false
LLM_THREADS=8
LLM_GPU_LAYERS=35
OLLAMA_BASE_URL=

# Generated URLs
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/ai_code_review
REDIS_URL=redis://:redis123@redis:6379/0
CELERY_BROKER_URL=redis://:redis123@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis123@redis:6379/0

# Database Performance Optimization
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100

# Neo4j Memory Settings
NEO4J_dbms_memory_heap_initial_size=512M
NEO4J_dbms_memory_heap_max_size=2G
NEO4J_dbms_memory_pagecache_size=1G

# Internal Docker Network Name
INTERNAL_NETWORK=ai_review_network
