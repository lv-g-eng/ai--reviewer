# ============================================================================
# AI Code Review Platform - Environment Configuration Template
# ============================================================================
# This file serves as a template for environment configuration.
# Copy this file to .env and fill in the required values.
# DO NOT commit the .env file to version control - it contains secrets.
# 
# IMPORTANT: All values marked as REQUIRED must be set before deployment.
# Optional values can be left empty to disable features.
# ============================================================================

# ============================================================================
# DATABASE CREDENTIALS (REQUIRED)
# ============================================================================
# PostgreSQL primary database credentials
# These are used by the backend application to connect to PostgreSQL.
# 
# POSTGRES_USER: Database user name (default: postgres)
# POSTGRES_PASSWORD: Database password (minimum 16 characters recommended)
#   Generate with: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here

# POSTGRES_DB: Database name (default: ai_code_review)
POSTGRES_DB=ai_code_review

# POSTGRES_HOST: PostgreSQL server hostname (default: postgres for Docker)
POSTGRES_HOST=postgres

# POSTGRES_PORT: PostgreSQL server port (default: 5432)
POSTGRES_PORT=5432

# ============================================================================
# NEO4J GRAPH DATABASE CREDENTIALS (REQUIRED)
# ============================================================================
# Neo4j is used for storing code relationships and analysis results.
# 
# NEO4J_USER: Neo4j user name (default: neo4j)
NEO4J_USER=neo4j

# NEO4J_PASSWORD: Neo4j password (minimum 16 characters recommended)
#   Generate with: openssl rand -hex 16
NEO4J_PASSWORD=your_secure_neo4j_password_here

# NEO4J_URI: Neo4j connection URI (default: bolt://neo4j:7687)
NEO4J_URI=bolt://neo4j:7687

# NEO4J_DATABASE: Neo4j database name (default: neo4j)
NEO4J_DATABASE=neo4j

# ============================================================================
# REDIS CACHE CREDENTIALS (REQUIRED)
# ============================================================================
# Redis is used for caching and as Celery message broker.
# 
# REDIS_HOST: Redis server hostname (default: redis for Docker)
REDIS_HOST=redis

# REDIS_PORT: Redis server port (default: 6379)
REDIS_PORT=6379

# REDIS_PASSWORD: Redis password (optional, but recommended for security)
#   Generate with: openssl rand -hex 16
#   Leave empty if Redis has no password
REDIS_PASSWORD=your_secure_redis_password_here

# REDIS_DB: Redis database number (default: 0)
REDIS_DB=0

# ============================================================================
# SECURITY SECRETS (REQUIRED)
# ============================================================================
# These secrets are critical for application security.
# NEVER use weak or default values in production.
# 
# JWT_SECRET: Secret key for signing JWT tokens (minimum 32 characters)
#   Generate with: openssl rand -hex 32
#   This must be kept secret and rotated periodically.
JWT_SECRET=your_32_character_jwt_secret_key_here_minimum_32_chars

# JWT_ALGORITHM: Algorithm for JWT signing (default: HS256)
#   Options: HS256, HS384, HS512, RS256, RS384, RS512
JWT_ALGORITHM=HS256

# JWT_EXPIRATION_HOURS: JWT token expiration time in hours (default: 24)
JWT_EXPIRATION_HOURS=24

# ACCESS_TOKEN_EXPIRE_MINUTES: Access token expiration in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# REFRESH_TOKEN_EXPIRE_DAYS: Refresh token expiration in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# SECRET_KEY: General application secret key (minimum 32 characters)
#   Generate with: openssl rand -hex 32
#   Used for session management and other security purposes.
SECRET_KEY=your_32_character_secret_key_here_minimum_32_chars

# SESSION_SECRET: Secret key for secure session management (minimum 32 characters)
#   Generate with: openssl rand -hex 32
SESSION_SECRET=your_32_character_session_secret_here_minimum_32_chars

# BCRYPT_ROUNDS: Number of rounds for bcrypt password hashing (default: 12)
#   Minimum: 12 (for security)
#   Higher values = slower hashing = more secure but slower login
#   Recommended: 12-14
BCRYPT_ROUNDS=12

# ============================================================================
# GITHUB INTEGRATION (OPTIONAL)
# ============================================================================
# GitHub integration allows the platform to analyze repositories.
# Leave empty to disable GitHub features.
# 
# GITHUB_TOKEN: GitHub personal access token
#   Generate at: https://github.com/settings/tokens
#   Required scopes: repo, read:user, read:org
#   Leave empty to disable GitHub integration.
GITHUB_TOKEN=

# GITHUB_WEBHOOK_SECRET: Secret for validating GitHub webhook signatures
#   Generate with: openssl rand -hex 32
#   Used to verify that webhooks come from GitHub.
#   Leave empty if not using webhooks.
GITHUB_WEBHOOK_SECRET=

# ============================================================================
# DATABASE CONNECTION PARAMETERS (COMPUTED)
# ============================================================================
# These are computed from the above credentials.
# You can override them if needed for special configurations.
# 
# DATABASE_URL: PostgreSQL connection URL
#   Format: postgresql://user:password@host:port/database
#   Leave empty to auto-generate from POSTGRES_* variables
DATABASE_URL=

# REDIS_URL: Redis connection URL
#   Format: redis://:password@host:port/db
#   Leave empty to auto-generate from REDIS_* variables
REDIS_URL=

# NEO4J_URL: Neo4j connection URL
#   Format: bolt://host:port or neo4j://host:port
#   Leave empty to auto-generate from NEO4J_* variables
NEO4J_URL=

# ============================================================================
# CELERY CONFIGURATION (REQUIRED)
# ============================================================================
# Celery is used for background task processing.
# 
# CELERY_BROKER_URL: Message broker URL (uses Redis)
#   Format: redis://:password@host:port/db
#   Leave empty to auto-generate from REDIS_* variables
CELERY_BROKER_URL=

# CELERY_RESULT_BACKEND: Result backend URL (uses Redis)
#   Format: redis://:password@host:port/db
#   Leave empty to auto-generate from REDIS_* variables
CELERY_RESULT_BACKEND=

# CELERY_WORKER_CONCURRENCY: Number of concurrent worker processes (default: 4)
#   Recommended: number of CPU cores
CELERY_WORKER_CONCURRENCY=4

# CELERY_TASK_TIME_LIMIT: Hard time limit for tasks in seconds (default: 3600)
#   Tasks exceeding this limit will be killed.
CELERY_TASK_TIME_LIMIT=3600

# CELERY_TASK_SOFT_TIME_LIMIT: Soft time limit for tasks in seconds (default: 3300)
#   Tasks exceeding this limit will receive a SoftTimeLimitExceeded exception.
CELERY_TASK_SOFT_TIME_LIMIT=3300

# ============================================================================
# OPTIONAL API KEYS
# ============================================================================
# These are optional and used for LLM integration.
# Leave empty to disable LLM features.
# 
# OPENAI_API_KEY: OpenAI API key for GPT models
#   Get from: https://platform.openai.com/api-keys
#   Required for using OpenAI models (GPT-3.5, GPT-4, etc.)
#   Leave empty to disable OpenAI integration.
OPENAI_API_KEY=

# ANTHROPIC_API_KEY: Anthropic API key for Claude models
#   Get from: https://console.anthropic.com/
#   Required for using Claude models.
#   Leave empty to disable Anthropic integration.
ANTHROPIC_API_KEY=

# DEFAULT_LLM_PROVIDER: Default LLM provider (default: openai)
#   Options: openai, anthropic
DEFAULT_LLM_PROVIDER=openai

# DEFAULT_LLM_MODEL: Default LLM model (default: gpt-4)
#   For OpenAI: gpt-4, gpt-3.5-turbo, etc.
#   For Anthropic: claude-3-opus, claude-3-sonnet, etc.
DEFAULT_LLM_MODEL=gpt-4

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# General application configuration.
# 
# ENVIRONMENT: Deployment environment (default: development)
#   Options: development, staging, production
#   Affects logging, error handling, and feature flags.
ENVIRONMENT=development

# DEBUG: Enable debug mode (default: false)
#   WARNING: Never enable in production - exposes sensitive information.
#   Options: true, false
DEBUG=false

# LOG_LEVEL: Logging level (default: INFO)
#   Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
#   DEBUG: Very detailed logging (development only)
#   INFO: General information about application operation
#   WARNING: Warning messages for potentially problematic situations
#   ERROR: Error messages for serious problems
#   CRITICAL: Critical errors that may cause application failure
LOG_LEVEL=INFO

# JSON_LOGGING: Enable JSON logging for log aggregation (default: false)
#   Options: true, false
#   Enable for production deployments with log aggregation systems.
JSON_LOGGING=false

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Configuration for frontend application.
# 
# NEXT_PUBLIC_API_URL: Backend API URL accessible from frontend
#   Used by frontend to make API requests.
#   Example: http://localhost:8000/api/v1 (development)
#   Example: https://api.example.com/api/v1 (production)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
# Performance tuning parameters.
# 
# RATE_LIMIT_PER_MINUTE: API rate limit (requests per minute, default: 60)
#   Prevents abuse and protects against DoS attacks.
RATE_LIMIT_PER_MINUTE=60

# REQUEST_TIMEOUT: Request timeout in seconds (default: 30)
#   Maximum time to wait for a request to complete.
REQUEST_TIMEOUT=30

# DB_POOL_SIZE: Database connection pool size (default: 20)
#   Number of connections to keep in the pool.
#   Increase for high-concurrency scenarios.
DB_POOL_SIZE=20

# DB_MAX_OVERFLOW: Maximum overflow connections (default: 10)
#   Additional connections allowed beyond pool size.
DB_MAX_OVERFLOW=10

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. Copy this file to .env:
#    cp .env.example .env
# 
# 2. Generate secure secrets:
#    # Generate 32-character hex strings for secrets
#    openssl rand -hex 32
# 
# 3. Fill in all REQUIRED values in .env:
#    - POSTGRES_PASSWORD
#    - NEO4J_PASSWORD
#    - REDIS_PASSWORD (recommended)
#    - JWT_SECRET
#    - SECRET_KEY
#    - SESSION_SECRET
# 
# 4. (Optional) Fill in optional values:
#    - GITHUB_TOKEN
#    - GITHUB_WEBHOOK_SECRET
#    - OPENAI_API_KEY
#    - ANTHROPIC_API_KEY
# 
# 5. Verify configuration:
#    python -m backend.app.core.config
# 
# 6. Start the application:
#    docker-compose up
# 
# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================
# 
# 1. NEVER commit .env to version control
#    Add to .gitignore: .env
# 
# 2. Use strong passwords (minimum 16 characters)
#    Generate with: openssl rand -hex 16
# 
# 3. Rotate secrets periodically
#    Especially JWT_SECRET and API keys
# 
# 4. Use different secrets for each environment
#    development, staging, production should have different values
# 
# 5. Restrict file permissions
#    chmod 600 .env
# 
# 6. Use environment-specific .env files
#    .env.development, .env.staging, .env.production
# 
# 7. Never log sensitive values
#    The application masks passwords and API keys in logs
# 
# 8. Use HTTPS in production
#    Set ENVIRONMENT=production and DEBUG=false
# 
# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# 
# Q: Application fails to start with "Missing required environment variable"
# A: Check that all REQUIRED variables are set in .env
#    Run: grep -E "^[A-Z_]+=" .env | wc -l
# 
# Q: Database connection fails
# A: Verify database credentials and connectivity
#    Check POSTGRES_HOST, POSTGRES_PORT, POSTGRES_PASSWORD
#    Ensure PostgreSQL service is running
# 
# Q: Redis connection fails
# A: Verify Redis is running and accessible
#    Check REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
#    Test with: redis-cli -h redis -p 6379 ping
# 
# Q: JWT token validation fails
# A: Ensure JWT_SECRET is set and consistent across restarts
#    Changing JWT_SECRET will invalidate all existing tokens
# 
# Q: Celery tasks not processing
# A: Verify Redis is running and accessible
#    Check CELERY_BROKER_URL and CELERY_RESULT_BACKEND
#    Ensure Celery worker is running
# 
# ============================================================================


# LLM Service Configuration

SERVICE_NAME=llm-service
PORT=8000

# Models Directory (mounted volume in Docker)
MODELS_DIR=/app/models

# Performance Settings
LLM_THREADS=8
LLM_GPU_LAYERS=35  # 0 for CPU-only, 35+ for GPU

# Logging
LOG_LEVEL=INFO
