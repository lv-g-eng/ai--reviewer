# ============================================================================
# AI Code Review Platform - Environment Configuration
# ============================================================================
# Main configuration file for Docker and local development
# ============================================================================

# ==================== Database Configuration ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=ai_code_review
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/ai_code_review

# PostgreSQL Performance
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== Redis Configuration ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_URL=redis://redis:redis123@redis:6379/0

# ==================== Neo4j Configuration ====================
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/neo4j123
NEO4J_server_memory_heap_initial__size=256M
NEO4J_server_memory_heap_max__size=512M
NEO4J_server_memory_pagecache_size=128M
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ==================== Security Secrets ====================
JWT_SECRET=dev_jwt_secret_key_32_chars_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SECRET_KEY=dev_secret_key_32_chars_minimum
SESSION_SECRET=dev_session_secret_32_chars
ENCRYPTION_KEY=dev_base64_encoded_32_byte_key

# ==================== Application Configuration ====================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PROJECT_NAME=AI Code Review Platform
API_V1_STR=/api/v1

# ==================== Server Configuration ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# ==================== CORS Configuration ====================
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== Celery Configuration ====================
CELERY_BROKER_URL=redis://redis:redis123@redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:redis123@redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# ==================== pgAdmin Configuration ====================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=postgres123

# ==================== GitHub Configuration ====================
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=webhook_secret_dev
GITHUB_API_URL=https://api.github.com

# ==================== Frontend Configuration ====================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=AI Code Review Platform
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev_session_secret_32_chars
NEXT_PUBLIC_SESSION_TIMEOUT=86400

# ==================== Frontend Feature Flags ====================
NEXT_PUBLIC_ENABLE_GITHUB_INTEGRATION=true
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG_MODE=true
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# ==================== Frontend Performance & UI ====================
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_MAX_RETRIES=3
NEXT_PUBLIC_RETRY_DELAY=1000
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_ITEMS_PER_PAGE=20
NEXT_PUBLIC_MAX_FILE_SIZE=10485760

# Graph Visualization Configuration
NEXT_PUBLIC_GRAPH_MAX_NODES=1000
NEXT_PUBLIC_GRAPH_PHYSICS_ENABLED=true
NEXT_PUBLIC_GRAPH_ZOOM_MIN=0.1
NEXT_PUBLIC_GRAPH_ZOOM_MAX=10

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=5

# Development Configuration
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_LOG_LEVEL=debug

# ==================== LLM API Configuration ====================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=2000

# OpenRouter API Configuration
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=anthropic/claude-3.5-sonnet

# LLM Service Configuration
LLM_ENABLED=false
LLM_THREADS=8
LLM_GPU_LAYERS=35
OLLAMA_BASE_URL=
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=5000
REQUEST_TIMEOUT=30

# ==================== Circuit Breaker ====================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# ==================== Monitoring & Observability ====================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== Backend Feature Flags ====================
ENABLE_GITHUB_INTEGRATION=true
ENABLE_LLM_ANALYSIS=true
ENABLE_ARCHITECTURE_ANALYSIS=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_AUDIT_LOGGING=true

# ==================== Testing Configuration ====================
TEST_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/ai_code_review_test
TEST_NEO4J_URI=bolt://localhost:7687
TEST_REDIS_URL=redis://localhost:6379/15

# ==================== Data Retention ====================
DATA_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_YEARS=1
BACKUP_RETENTION_DAYS=7

# ==================== Performance Tuning ====================
ASYNC_POOL_SIZE=100
MAX_CONCURRENT_REQUESTS=100
KEEPALIVE_TIMEOUT=5

# ==================== Internal Docker Network ====================
INTERNAL_NETWORK=ai_review_network
