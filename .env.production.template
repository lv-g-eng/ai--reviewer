# ============================================================================
# AI Code Review Platform - Production Environment Configuration
# ============================================================================
# SECURITY WARNING: This file contains sensitive production configuration
# - Copy this to .env.production and customize for your deployment
# - NEVER commit .env.production to version control
# - Use strong, randomly generated passwords for all services
# - Rotate secrets regularly (at least every 90 days)
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
PROJECT_NAME="AI Code Review Platform"
API_V1_STR=/api/v1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL - Primary Database
POSTGRES_DB=ai_code_review_prod
POSTGRES_USER=ai_review_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# PostgreSQL Performance Tuning (Production)
POSTGRES_SHARED_BUFFERS=2GB
POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
POSTGRES_WORK_MEM=128MB
POSTGRES_MAINTENANCE_WORK_MEM=512MB
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_MAX_WORKER_PROCESSES=8
POSTGRES_MAX_PARALLEL_WORKERS=8

# Connection Pool Settings
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# NEO4J CONFIGURATION
# ============================================================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}

# Neo4j Performance Tuning (Production)
NEO4J_dbms_memory_heap_initial_size=2G
NEO4J_dbms_memory_heap_max_size=4G
NEO4J_dbms_memory_pagecache_size=2G
NEO4J_dbms_tx_log_rotation_retention_policy=7 days
NEO4J_dbms_checkpoint_interval_time=15m

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ============================================================================
# SECURITY SECRETS
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8
JWT_REFRESH_EXPIRATION_DAYS=30

SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_ENVIRONMENT=production

# ============================================================================
# RATE LIMITING & SECURITY
# ============================================================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000
RATE_LIMIT_PER_DAY=50000
LOGIN_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=100

REQUEST_TIMEOUT=60
MAX_REQUEST_SIZE=20MB
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Security Headers (Requirement 8.5)
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
ENABLE_CSP=true
ENABLE_RATE_LIMITING=true

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2
CELERY_WORKER_CONCURRENCY=8
CELERY_TASK_TIME_LIMIT=7200
CELERY_TASK_SOFT_TIME_LIMIT=6600
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_TASK_REJECT_ON_WORKER_LOST=true

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=https://your-domain.com/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
GITHUB_TOKEN=your_github_personal_access_token

# ============================================================================
# LLM PROVIDERS
# ============================================================================
# OpenRouter (Recommended for production - supports multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=anthropic/claude-3.5-sonnet

# Alternative Providers (Optional)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OLLAMA_BASE_URL=

# LLM Configuration
LLM_ENABLED=true
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# OpenTelemetry / AWS X-Ray
TRACING_ENABLED=true
OTLP_ENDPOINT=http://otel-collector:4317
TRACING_SAMPLE_RATE=0.1
TRACING_CONSOLE_EXPORT=false

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/ai-review/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10
LOG_ROTATION=daily

# ============================================================================
# BACKUP & DISASTER RECOVERY
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME="AI Code Review Platform"
SMTP_USE_TLS=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REGISTRATION=false
ENABLE_GITHUB_OAUTH=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=true
ENABLE_API_DOCS=false
ENABLE_ADMIN_PANEL=true

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
WORKER_PROCESSES=4
WORKER_THREADS=2
WORKER_TIMEOUT=120
KEEPALIVE_TIMEOUT=65
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100

# Cache TTL (seconds)
CACHE_DEFAULT_TTL=300
CACHE_USER_TTL=600
CACHE_PROJECT_TTL=1800
CACHE_ANALYTICS_TTL=3600

# ============================================================================
# COMPUTED URLS (DO NOT MODIFY)
# ============================================================================
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
