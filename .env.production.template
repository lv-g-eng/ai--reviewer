# ============================================================================
# AI Code Review Platform - Production Environment Template
# ============================================================================
# SECURITY NOTICE: This is a template file. Copy to .env.production and
# replace all placeholder values with actual production secrets.
# NEVER commit production secrets to version control!
# ============================================================================

# ==================== Environment & Application ====================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
PROJECT_NAME=AI Code Review Platform
API_V1_STR=/api/v1
VERSION=1.0.0

# ==================== Server Configuration ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# ==================== SECURITY CONFIGURATION - PRODUCTION ====================
# CRITICAL: Replace ALL values below with actual production secrets
# Use AWS Secrets Manager, Azure Key Vault, or HashiCorp Vault

# JWT Configuration - MUST BE CHANGED
AUTH_JWT_SECRET_KEY=${AWS_SECRET_MANAGER_JWT_SECRET}
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Legacy JWT support (will be deprecated)
JWT_SECRET=${AWS_SECRET_MANAGER_JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1

# Application secrets - MUST BE CHANGED
SECRET_KEY=${AWS_SECRET_MANAGER_APP_SECRET}
SESSION_SECRET=${AWS_SECRET_MANAGER_SESSION_SECRET}

# Password Security - Production grade
AUTH_BCRYPT_ROUNDS=14

# Session Configuration - Secure
AUTH_SESSION_EXPIRE_MINUTES=60
AUTH_ALLOW_CONCURRENT_SESSIONS=false

# Database Encryption - MUST BE CHANGED
DATABASE_ENCRYPTION_KEY=${AWS_SECRET_MANAGER_DB_ENCRYPTION_KEY}
ENCRYPTION_KEY=${AWS_SECRET_MANAGER_ENCRYPTION_KEY}

# HTTPS Configuration - REQUIRED in production
FORCE_HTTPS=true
SECURE_COOKIES=true
SECURE_HEADERS=true

# Rate Limiting - Production values
LOGIN_RATE_LIMIT_REQUESTS=3
LOGIN_RATE_LIMIT_WINDOW=300
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=60

# ==================== Database Configuration ====================
# PostgreSQL - Use RDS or managed database service
POSTGRES_HOST=${RDS_ENDPOINT}
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_review_prod
POSTGRES_USER=${RDS_USERNAME}
POSTGRES_PASSWORD=${RDS_PASSWORD}
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Connection Pool Settings - Production optimized
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== Redis Configuration ====================
# Redis - Use ElastiCache or managed Redis service
REDIS_HOST=${ELASTICACHE_ENDPOINT}
REDIS_PORT=6379
REDIS_PASSWORD=${ELASTICACHE_PASSWORD}
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Redis Connection Pool
REDIS_POOL_SIZE=20
REDIS_POOL_TIMEOUT=5

# ==================== Neo4j Configuration ====================
# Neo4j - Use Neo4j AuraDB or managed service
NEO4J_URI=${NEO4J_AURA_URI}
NEO4J_USER=${NEO4J_AURA_USER}
NEO4J_PASSWORD=${NEO4J_AURA_PASSWORD}
NEO4J_DATABASE=neo4j

# ==================== External Services ====================
# GitHub Integration
GITHUB_TOKEN=${GITHUB_PRODUCTION_TOKEN}
GITHUB_WEBHOOK_SECRET=${GITHUB_WEBHOOK_SECRET}
GITHUB_APP_ID=${GITHUB_APP_ID}
GITHUB_APP_PRIVATE_KEY=${GITHUB_APP_PRIVATE_KEY}

# LLM API Keys
OPENAI_API_KEY=${OPENAI_PRODUCTION_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_PRODUCTION_KEY}
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4-turbo

# LM Studio (if using local inference)
LMSTUDIO_BASE_URL=${LMSTUDIO_ENDPOINT}
LMSTUDIO_MODEL=${LMSTUDIO_MODEL_NAME}
LMSTUDIO_TIMEOUT=120

# Ollama (if using local inference)
OLLAMA_BASE_URL=${OLLAMA_ENDPOINT}
OLLAMA_MODEL=qwen2.5-coder

# ==================== Message Queue Configuration ====================
# Celery with Redis broker
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Worker Configuration
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ==================== Monitoring & Logging ====================
# Sentry for error tracking
SENTRY_DSN=${SENTRY_PRODUCTION_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# CloudWatch Logs (if using AWS)
AWS_REGION=${AWS_REGION}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
CLOUDWATCH_LOG_GROUP=/aws/ecs/ai-code-review
CLOUDWATCH_LOG_STREAM=production

# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PORT=9090

# ==================== Email Configuration ====================
# SMTP for notifications
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_TLS=true
FROM_EMAIL=noreply@yourcompany.com

# ==================== File Storage ====================
# AWS S3 for file storage
AWS_S3_BUCKET=${S3_BUCKET_NAME}
AWS_S3_REGION=${AWS_REGION}
AWS_S3_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
AWS_S3_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}

# ==================== CDN Configuration ====================
# CloudFront or similar CDN
CDN_URL=${CLOUDFRONT_DISTRIBUTION_URL}
STATIC_URL=${CDN_URL}/static/
MEDIA_URL=${CDN_URL}/media/

# ==================== Security Headers ====================
# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_FONT_SRC='self'
CSP_CONNECT_SRC='self' ${API_DOMAIN}

# HSTS Configuration
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ==================== Performance Configuration ====================
# Caching
CACHE_TTL=300
CACHE_MAX_ENTRIES=10000

# Database Query Optimization
DB_QUERY_TIMEOUT=30
DB_STATEMENT_TIMEOUT=60

# API Response Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# ==================== Backup Configuration ====================
# Database Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_S3_BUCKET=${BACKUP_S3_BUCKET}

# ==================== Health Check Configuration ====================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# ==================== Feature Flags ====================
FEATURE_AI_REVIEW_ENABLED=true
FEATURE_GITHUB_INTEGRATION_ENABLED=true
FEATURE_REAL_TIME_NOTIFICATIONS_ENABLED=true
FEATURE_ADVANCED_ANALYTICS_ENABLED=true

# ==================== Compliance & Audit ====================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=365
COMPLIANCE_MODE=SOC2  # SOC2, HIPAA, PCI, etc.

# ==================== Deployment Information ====================
DEPLOYMENT_VERSION=${CI_COMMIT_SHA}
DEPLOYMENT_DATE=${CI_PIPELINE_CREATED_AT}
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=${AWS_REGION}

# ============================================================================
# SECURITY CHECKLIST:
# ============================================================================
# [ ] All placeholder values replaced with actual secrets
# [ ] Secrets stored in secure secret management service
# [ ] DEBUG=false
# [ ] FORCE_HTTPS=true
# [ ] SECURE_COOKIES=true
# [ ] Strong bcrypt rounds (14+)
# [ ] Concurrent sessions disabled
# [ ] Rate limiting configured
# [ ] Monitoring and logging enabled
# [ ] Backup strategy implemented
# [ ] Security headers configured
# [ ] Database connections encrypted
# [ ] API keys rotated regularly
# [ ] Access logs enabled
# ============================================================================