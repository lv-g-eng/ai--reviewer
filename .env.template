# ============================================================================
# AI Code Review Platform - Docker Environment Configuration Template
# ============================================================================
# This template should be copied to .env and customized for your deployment
# DO NOT commit the actual .env file to version control
# ============================================================================

# Database Configuration
POSTGRES_DB=ai_code_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j Configuration
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_URI=bolt://neo4j:7687
NEO4J_DATABASE=neo4j
NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Security Secrets (Generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SECRET_KEY=your_app_secret_min_32_chars
SESSION_SECRET=your_session_secret_min_32_chars

# Application Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
PROJECT_NAME="AI Code Review Platform"
API_V1_STR=/api/v1

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Performance Settings
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT=30
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Celery Configuration
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# Optional API Keys
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_WEBHOOK_SECRET=

# LLM Service (Optional)
LLM_ENABLED=false
LLM_THREADS=8
LLM_GPU_LAYERS=35
OLLAMA_BASE_URL=

# Generated URLs (automatically computed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ============================================================================
# Database Performance Optimization
# ============================================================================
# PostgreSQL Memory Settings
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100

# Neo4j Memory Settings
NEO4J_dbms_memory_heap_initial_size=512M
NEO4J_dbms_memory_heap_max_size=2G
NEO4J_dbms_memory_pagecache_size=1G

# ============================================================================
# Network Configuration
# ============================================================================
# Internal Docker Network Name (Auto-generated)
INTERNAL_NETWORK=ai_review_network