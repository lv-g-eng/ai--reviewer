#!/bin/bash
# Pre-commit hook for quality checks
# 在每次提交前自动运行质量检查

echo "🔍 运行提交前质量检查..."

# 检查是否有暂存的文件
if git diff --cached --quiet; then
    echo "没有暂存的文件，跳过检查"
    exit 0
fi

# 运行快速质量检查
QUICK_CHECK=true

# 1. 检查代码风格
echo "📝 检查代码风格..."

# 前端代码风格检查
if git diff --cached --name-only | grep -E '\.(js|ts|tsx|jsx)$' > /dev/null; then
    if [ -d "frontend" ]; then
        cd frontend
        if ! npm run lint --silent; then
            echo "❌ 前端代码风格检查失败"
            exit 1
        fi
        cd ..
    fi
fi

# 后端代码风格检查
if git diff --cached --name-only | grep -E '\.py$' > /dev/null; then
    if [ -d "backend" ]; then
        cd backend
        if ! python -m ruff check . --quiet; then
            echo "❌ 后端代码风格检查失败"
            exit 1
        fi
        cd ..
    fi
fi

# 2. 检查是否有明显的重复代码
echo "🔍 检查重复代码..."
CHANGED_FILES=$(git diff --cached --name-only | grep -E '\.(py|js|ts|tsx|jsx)$' | head -10)

if [ ! -z "$CHANGED_FILES" ]; then
    # 创建临时文件列表
    echo "$CHANGED_FILES" > /tmp/changed_files.txt
    
    # 运行简化的重复检查
    python -c "
import sys
import os
from pathlib import Path

# 简单的重复代码检查
def check_duplicates(files):
    content_hashes = {}
    duplicates = []
    
    for file_path in files:
        if not os.path.exists(file_path):
            continue
            
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                lines = f.readlines()
            
            # 检查连续10行的重复
            for i in range(len(lines) - 10):
                chunk = ''.join(lines[i:i+10]).strip()
                if len(chunk) > 100:  # 忽略太短的代码块
                    chunk_hash = hash(chunk)
                    if chunk_hash in content_hashes:
                        duplicates.append((file_path, content_hashes[chunk_hash], i+1))
                    else:
                        content_hashes[chunk_hash] = (file_path, i+1)
        except:
            continue
    
    return duplicates

# 读取变更的文件
with open('/tmp/changed_files.txt', 'r') as f:
    files = [line.strip() for line in f if line.strip()]

duplicates = check_duplicates(files)
if duplicates:
    print('⚠️ 发现可能的重复代码:')
    for dup in duplicates[:3]:  # 只显示前3个
        print(f'  {dup[0]}:{dup[2]} 与 {dup[1][0]}:{dup[1][1]} 相似')
    print('建议在提交前检查并重构重复代码')
    sys.exit(1)
"
    
    if [ $? -ne 0 ]; then
        echo "❌ 发现重复代码，请重构后再提交"
        exit 1
    fi
fi

# 3. 检查提交信息格式
COMMIT_MSG_FILE="$1"
if [ ! -z "$COMMIT_MSG_FILE" ] && [ -f "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    
    # 检查提交信息格式 (简化版)
    if [[ ! "$COMMIT_MSG" =~ ^(feat|fix|docs|style|refactor|test|chore)(\(.+\))?: .+ ]]; then
        echo "⚠️ 提交信息格式建议: type(scope): description"
        echo "   例如: feat(auth): add user login validation"
    fi
fi

echo "✅ 提交前检查通过"
exit 0