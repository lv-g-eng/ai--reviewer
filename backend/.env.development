# ============================================================================
# Development Environment Configuration
# ============================================================================
# This file contains development-specific settings
# Copy to .env for local development
# ============================================================================

# Application Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
PROJECT_NAME="AI Code Review Platform - Development"
API_V1_STR=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=2
RELOAD=true

# Security Configuration (Development - Use secure values in production!)
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SESSION_SECRET=dev_session_secret_min_32_chars

# TLS/SSL Configuration (Disabled for development)
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=
SSL_CA_FILE=
SSL_VERIFY_MODE=CERT_OPTIONAL

# Data Encryption at Rest (Development key - DO NOT use in production!)
ENCRYPTION_KEY=dev_base64_encoded_32_byte_key_change_in_production
AWS_KMS_KEY_ID=

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_review_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database Connection Pool (Small for development)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=10
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# GitHub Integration (Optional for development)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com

# LLM API Configuration (Optional for development)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=2000

# LLM Service Configuration
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# Rate Limiting (Relaxed for development)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/2

# Request Timeout
REQUEST_TIMEOUT=60

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# Monitoring and Observability
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# AWS Configuration (Not used in development)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_SECRETS_MANAGER_ENABLED=false

# CORS Configuration (Permissive for development)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Feature Flags
ENABLE_GITHUB_INTEGRATION=false
ENABLE_LLM_ANALYSIS=false
ENABLE_ARCHITECTURE_ANALYSIS=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_AUDIT_LOGGING=true

# Testing Configuration
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_code_review_test
TEST_NEO4J_URI=bolt://localhost:7687
TEST_REDIS_URL=redis://localhost:6379/15

# Data Retention
DATA_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_YEARS=1
BACKUP_RETENTION_DAYS=7

# Performance Tuning (Lower for development)
ASYNC_POOL_SIZE=50
MAX_CONCURRENT_REQUESTS=100
KEEPALIVE_TIMEOUT=5
