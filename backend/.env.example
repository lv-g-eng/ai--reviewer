# ============================================================================
# Backend Environment Configuration Template
# ============================================================================
# Copy this file to .env and customize for your environment
# DO NOT commit the actual .env file to version control
# ============================================================================

# Application Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PROJECT_NAME="AI Code Review Platform"
API_V1_STR=/api/v1
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# Security Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_min_32_chars_change_in_production
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SESSION_SECRET=your_session_secret_min_32_chars

# TLS/SSL Configuration (Requirement 8.5)
# For development: python backend/scripts/generate_ssl_certs.py
# For production: Use certificates from trusted CA (Let's Encrypt, AWS ACM)
SSL_ENABLED=false
SSL_CERT_FILE=certs/server.crt
SSL_KEY_FILE=certs/server.key
SSL_CA_FILE=
SSL_VERIFY_MODE=CERT_REQUIRED

# Data Encryption at Rest (Requirement 8.4)
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your_base64_encoded_32_byte_key_change_in_production
# AWS KMS Key ID for encryption key management (optional, for production)
AWS_KMS_KEY_ID=

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_API_URL=https://api.github.com

# LLM API Configuration
# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=2000

# LLM Service Configuration
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1

# Request Timeout
REQUEST_TIMEOUT=30

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# Monitoring and Observability
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# OpenTelemetry Distributed Tracing (Requirement 18.1)
TRACING_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
TRACING_SAMPLE_RATE=1.0
TRACING_CONSOLE_EXPORT=false

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# CloudWatch Logs Configuration (Requirement 7.2, 7.10)
CLOUDWATCH_ENABLED=true
SERVICE_NAME=backend-api
INSTANCE_ID=local

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_SECRETS_MANAGER_ENABLED=false

# Feature Flags
ENABLE_GITHUB_INTEGRATION=true
ENABLE_LLM_ANALYSIS=true
ENABLE_ARCHITECTURE_ANALYSIS=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_AUDIT_LOGGING=true

# Testing Configuration
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_code_review_test
TEST_NEO4J_URI=bolt://localhost:7687
TEST_REDIS_URL=redis://localhost:6379/15

# Data Retention
DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_YEARS=7
BACKUP_RETENTION_DAYS=7

# Performance Tuning
ASYNC_POOL_SIZE=100
MAX_CONCURRENT_REQUESTS=1000
KEEPALIVE_TIMEOUT=5
