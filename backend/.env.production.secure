# ============================================================================
# Production Environment Configuration
# ============================================================================
# CRITICAL: This file must be customized for your production environment
# All sensitive values MUST be loaded from AWS Secrets Manager
# DO NOT commit actual values to version control
# ============================================================================

# Application Configuration
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
PROJECT_NAME="AI Code Review Platform"
API_V1_STR=/api/v1
VERSION=1.0.0

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=8
RELOAD=false

# ========================================
# SECURITY CONFIGURATION - USE AWS SECRETS
# ========================================

# Generate secure keys:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# Store these in AWS Secrets Manager:
# - production/app/secret_key
# - production/app/jwt_secret
# - production/app/session_secret
# - production/database/postgres_password
# - production/database/neo4j_password
# - production/database/redis_password
# - production/app/encryption_key
# - production/app/kms_key_id

SECRET_KEY=${AWS_SECRET:production/app/secret_key}
JWT_SECRET=${AWS_SECRET:production/app/jwt_secret}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=4
SESSION_SECRET=${AWS_SECRET:production/app/session_secret}

# TLS/SSL Configuration (Terminated at ALB/Nginx)
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=
SSL_CA_FILE=
SSL_VERIFY_MODE=CERT_REQUIRED

# Data Encryption at Rest - AWS KMS
ENCRYPTION_KEY=${AWS_SECRET:production/app/encryption_key}
AWS_KMS_KEY_ID=${AWS_SECRET:production/app/kms_key_id}

# ========================================
# DATABASE CONFIGURATION - USE RDS/MANAGED SERVICES
# ========================================

# PostgreSQL RDS Multi-AZ
POSTGRES_HOST=${AWS_SECRET:production/database/postgres_host}
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_review_prod
POSTGRES_USER=${AWS_SECRET:production/database/postgres_user}
POSTGRES_PASSWORD=${AWS_SECRET:production/database/postgres_password}

# Database Connection Pool (Production sizing)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Neo4j AuraDB Enterprise
NEO4J_URI=${AWS_SECRET:production/database/neo4j_uri}
NEO4J_USER=${AWS_SECRET:production/database/neo4j_user}
NEO4J_PASSWORD=${AWS_SECRET:production/database/neo4j_password}
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# ElastiCache Redis Multi-AZ
REDIS_HOST=${AWS_SECRET:production/database/redis_host}
REDIS_PORT=6379
REDIS_PASSWORD=${AWS_SECRET:production/database/redis_password}
REDIS_DB=0

# ========================================
# CELERY CONFIGURATION
# ========================================

CELERY_BROKER_URL=redis://:${AWS_SECRET:production/database/redis_password}@${AWS_SECRET:production/database/redis_host}:6379/0
CELERY_RESULT_BACKEND=redis://:${AWS_SECRET:production/database/redis_password}@${AWS_SECRET:production/database/redis_host}:6379/1
CELERY_WORKER_CONCURRENCY=8
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1650
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# ========================================
# EXTERNAL INTEGRATIONS - USE AWS SECRETS
# ========================================

# GitHub Integration
GITHUB_TOKEN=${AWS_SECRET:production/integrations/github_token}
GITHUB_WEBHOOK_SECRET=${AWS_SECRET:production/integrations/github_webhook_secret}
GITHUB_CLIENT_ID=${AWS_SECRET:production/oauth/github_client_id}
GITHUB_CLIENT_SECRET=${AWS_SECRET:production/oauth/github_client_secret}
GITHUB_API_URL=https://api.github.com

# ========================================
# LLM API CONFIGURATION - USE AWS SECRETS
# ========================================

# Primary LLM Provider
LLM_PRIMARY_PROVIDER=openai
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4-turbo-preview

# OpenAI
OPENAI_API_KEY=${AWS_SECRET:production/llm/openai_api_key}
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Anthropic (Fallback)
ANTHROPIC_API_KEY=${AWS_SECRET:production/llm/anthropic_api_key}
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4000

# OpenRouter (Multi-model support)
OPENROUTER_API_KEY=${AWS_SECRET:production/llm/openrouter_api_key}
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Service Configuration
LLM_ENABLED=true
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# Local LLM (Ollama)
OLLAMA_BASE_URL=

# ========================================
# RATE LIMITING & SECURITY
# ========================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=200
RATE_LIMIT_PER_HOUR=10000
RATE_LIMIT_STORAGE_URL=redis://:${AWS_SECRET:production/database/redis_password}@${AWS_SECRET:production/database/redis_host}:6379/2

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# Request Timeout
REQUEST_TIMEOUT=300

# CORS Configuration - RESTRICT IN PRODUCTION
ALLOWED_HOSTS=app.example.com,www.example.com,api.example.com
CORS_ORIGINS=https://app.example.com,https://www.example.com

# ========================================
# MONITORING & OBSERVABILITY
# ========================================

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# OpenTelemetry Tracing
ENABLE_TRACING=true
JAEGER_AGENT_HOST=otel-collector
JAEGER_AGENT_PORT=6831
OTLP_ENDPOINT=http://otel-collector:4317
TRACING_SAMPLE_RATE=0.1
TRACING_CONSOLE_EXPORT=false

# ========================================
# LOGGING CONFIGURATION
# ========================================

LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ========================================
# AWS CONFIGURATION
# ========================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_SECRET:production/aws/access_key_id}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET:production/aws/secret_access_key}
AWS_SECRETS_MANAGER_ENABLED=true

# CloudWatch Configuration
ENABLE_CLOUDWATCH=true
CLOUDWATCH_LOG_GROUP=/ai-code-review/backend
CLOUDWATCH_NAMESPACE=AICodeReview

# ========================================
# FEATURE FLAGS
# ========================================

ENABLE_GITHUB_INTEGRATION=true
ENABLE_LLM_ANALYSIS=true
ENABLE_ARCHITECTURE_ANALYSIS=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_AUDIT_LOGGING=true

# ========================================
# DATA RETENTION & BACKUP
# ========================================

# Data Lifecycle
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_YEARS=3
BACKUP_RETENTION_DAYS=90

# ========================================
# PERFORMANCE TUNING
# ========================================

ASYNC_POOL_SIZE=200
MAX_CONCURRENT_REQUESTS=500
KEEPALIVE_TIMEOUT=65

# ========================================
# CORS and SECURITY HEADERS
# ========================================

# Security Headers (Configured via middleware)
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
ENABLE_CSP=true
CSP_HEADER=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline';

# ========================================
# EOF - Production Configuration
# ========================================
# Last updated: 2026-03-07
# Verification: Ensure all AWS Secrets are created before deployment
# Security: Never commit real values to version control
