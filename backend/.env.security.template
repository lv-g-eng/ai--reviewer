# Security Configuration Template
# Copy this file to .env.production and fill in secure values

# JWT Configuration - CRITICAL: Change these in production
AUTH_JWT_SECRET_KEY=your-super-secure-256-bit-secret-key-here
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours
AUTH_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Security
AUTH_BCRYPT_ROUNDS=12  # Minimum 12 for security

# Session Configuration
AUTH_SESSION_EXPIRE_MINUTES=1440  # 24 hours
AUTH_ALLOW_CONCURRENT_SESSIONS=true

# Database Encryption (for sensitive fields like GitHub tokens)
DATABASE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Redis Configuration for token blacklist
REDIS_URL=redis://localhost:6379/0

# HTTPS Configuration (production only)
FORCE_HTTPS=true
SECURE_COOKIES=true

# Rate Limiting
LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW=60  # seconds

# Account Lockout
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900  # 15 minutes in seconds