# ============================================================================
# Staging Environment Configuration
# ============================================================================
# This file contains staging-specific settings
# Deploy to staging environment via CI/CD
# Sensitive values should be stored in AWS Secrets Manager
# ============================================================================

# Application Configuration
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO
PROJECT_NAME="AI Code Review Platform - Staging"
API_V1_STR=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Security Configuration
# IMPORTANT: These should be loaded from AWS Secrets Manager in production
# Placeholders here for reference only
SECRET_KEY=${AWS_SECRET:staging/app/secret_key}
JWT_SECRET=${AWS_SECRET:staging/app/jwt_secret}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
SESSION_SECRET=${AWS_SECRET:staging/app/session_secret}

# TLS/SSL Configuration (Enabled via ALB)
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=
SSL_CA_FILE=
SSL_VERIFY_MODE=CERT_REQUIRED

# Data Encryption at Rest
ENCRYPTION_KEY=${AWS_SECRET:staging/app/encryption_key}
AWS_KMS_KEY_ID=${AWS_SECRET:staging/app/kms_key_id}

# PostgreSQL Database Configuration
POSTGRES_HOST=${AWS_SECRET:staging/database/postgres_host}
POSTGRES_PORT=5432
POSTGRES_DB=ai_code_review_staging
POSTGRES_USER=${AWS_SECRET:staging/database/postgres_user}
POSTGRES_PASSWORD=${AWS_SECRET:staging/database/postgres_password}

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Neo4j Graph Database Configuration
NEO4J_URI=${AWS_SECRET:staging/database/neo4j_uri}
NEO4J_USER=${AWS_SECRET:staging/database/neo4j_user}
NEO4J_PASSWORD=${AWS_SECRET:staging/database/neo4j_password}
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Redis Configuration
REDIS_HOST=${AWS_SECRET:staging/database/redis_host}
REDIS_PORT=6379
REDIS_PASSWORD=${AWS_SECRET:staging/database/redis_password}
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://:${AWS_SECRET:staging/database/redis_password}@${AWS_SECRET:staging/database/redis_host}:6379/0
CELERY_RESULT_BACKEND=redis://:${AWS_SECRET:staging/database/redis_password}@${AWS_SECRET:staging/database/redis_host}:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# GitHub Integration
GITHUB_TOKEN=${AWS_SECRET:staging/integrations/github_token}
GITHUB_WEBHOOK_SECRET=${AWS_SECRET:staging/integrations/github_webhook_secret}
GITHUB_API_URL=https://api.github.com

# LLM API Configuration
OPENAI_API_KEY=${AWS_SECRET:staging/integrations/openai_api_key}
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=${AWS_SECRET:staging/integrations/anthropic_api_key}
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=2000

# LLM Service Configuration
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000
RATE_LIMIT_STORAGE_URL=redis://:${AWS_SECRET:staging/database/redis_password}@${AWS_SECRET:staging/database/redis_host}:6379/2

# Request Timeout
REQUEST_TIMEOUT=30

# Circuit Breaker Configuration
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=Exception

# Monitoring and Observability
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/app/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=ai-code-review-staging
AWS_SECRETS_MANAGER_ENABLED=true

# CORS Configuration
ALLOWED_HOSTS=staging.example.com
CORS_ORIGINS=https://staging.example.com

# Feature Flags
ENABLE_GITHUB_INTEGRATION=true
ENABLE_LLM_ANALYSIS=true
ENABLE_ARCHITECTURE_ANALYSIS=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_AUDIT_LOGGING=true

# Testing Configuration (Not used in staging)
TEST_DATABASE_URL=
TEST_NEO4J_URI=
TEST_REDIS_URL=

# Data Retention
DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_YEARS=7
BACKUP_RETENTION_DAYS=7

# Performance Tuning
ASYNC_POOL_SIZE=100
MAX_CONCURRENT_REQUESTS=500
KEEPALIVE_TIMEOUT=5
