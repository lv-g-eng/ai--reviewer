{
  "name": "@project/common",
  "version": "1.0.0",
  "description": "Common library for frontend and backend shared utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "common",
    "utilities",
    "validators",
    "components",
    "shared"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "@types/react": ">=16.8.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./frontend/*": {
      "types": "./dist/frontend/*.d.ts",
      "import": "./dist/frontend/*.js",
      "require": "./dist/frontend/*.js"
    },
    "./shared/*": {
      "types": "./dist/shared/*.d.ts",
      "import": "./dist/shared/*.js",
      "require": "./dist/shared/*.js"
    }
  }
}