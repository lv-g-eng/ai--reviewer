@startuml CI/CD Pipeline
!theme plain
skinparam backgroundColor #FFFFFF

title AI-Based Code Reviewer - CI/CD Pipeline

|Developer|
start
:Developer commits code;
:Push to GitHub;

|GitHub Actions|
:Trigger workflow;
fork
  :Checkout code;
fork again
  :Setup environment;
end fork

partition "Build Stage" {
  :Install dependencies;
  :Build application;
  if (Build successful?) then (yes)
    :Create build artifacts;
  else (no)
    #Pink:Build failed;
    :Notify developer;
    stop
  endif
}

partition "Test Stage" {
  fork
    :Run unit tests;
    :Generate coverage report;
  fork again
    :Run integration tests;
  fork again
    :Run E2E tests;
  end fork
  
  if (All tests passed?) then (yes)
    :Merge test results;
  else (no)
    #Pink:Tests failed;
    :Notify developer;
    stop
  endif
  
  if (Coverage >= 80%?) then (yes)
    :Continue;
  else (no)
    #Pink:Coverage too low;
    :Notify developer;
    stop
  endif
}

partition "Code Quality Stage" {
  fork
    :SonarQube analysis;
    note right
      - Code smells
      - Bugs
      - Vulnerabilities
      - Duplications
    end note
  fork again
    :ESLint/Pylint;
    note right
      - Style violations
      - Best practices
    end note
  fork again
    :Type checking;
    note right
      - TypeScript
      - mypy (Python)
    end note
  end fork
  
  if (Quality gate passed?) then (yes)
    :Continue;
  else (no)
    #Pink:Quality issues;
    :Notify developer;
    stop
  endif
}

partition "Security Scan Stage" {
  fork
    :Snyk dependency scan;
    note right
      - Known vulnerabilities
      - License issues
    end note
  fork again
    :Trivy container scan;
    note right
      - OS vulnerabilities
      - Misconfigurations
    end note
  fork again
    :OWASP dependency check;
    note right
      - CVE database
      - Security advisories
    end note
  fork again
    :Secret scanning;
    note right
      - API keys
      - Passwords
      - Tokens
    end note
  end fork
  
  if (No critical vulnerabilities?) then (yes)
    :Continue;
  else (no)
    #Pink:Security issues found;
    :Create security ticket;
    :Notify security team;
    stop
  endif
}

partition "Build Docker Images" {
  :Build Docker images;
  note right
    - Frontend image
    - API services images
    - Worker images
  end note
  
  :Tag images;
  note right
    - git commit SHA
    - branch name
    - timestamp
  end note
  
  :Push to ECR;
}

if (Branch?) then (main/master)
  partition "Deploy to Staging" {
    :Update Kubernetes manifests;
    :Apply to staging cluster;
    :Wait for rollout;
    
    if (Deployment successful?) then (yes)
      :Run smoke tests;
    else (no)
      #Pink:Deployment failed;
      :Rollback;
      :Notify DevOps;
      stop
    endif
    
    if (Smoke tests passed?) then (yes)
      :Continue;
    else (no)
      #Pink:Smoke tests failed;
      :Rollback;
      :Notify developer;
      stop
    endif
  }
  
  partition "Manual Approval" {
    :Notify QA team;
    :Wait for approval;
    
    if (Approved?) then (yes)
      :Continue to production;
    else (no)
      #Pink:Deployment rejected;
      stop
    endif
  }
  
  partition "Deploy to Production" {
    :Create deployment tag;
    :Backup current state;
    
    :Blue-Green deployment;
    note right
      1. Deploy to green environment
      2. Run health checks
      3. Switch traffic gradually
      4. Monitor metrics
      5. Complete switch or rollback
    end note
    
    if (Health checks passed?) then (yes)
      :Switch traffic to new version;
      :Monitor for 15 minutes;
      
      if (No errors detected?) then (yes)
        :Complete deployment;
        #LightGreen:Deployment successful;
      else (no)
        #Pink:Errors detected;
        :Automatic rollback;
        :Notify DevOps;
        stop
      endif
    else (no)
      #Pink:Health checks failed;
      :Automatic rollback;
      :Notify DevOps;
      stop
    endif
  }
  
  partition "Post-Deployment" {
    :Update documentation;
    :Create release notes;
    :Notify stakeholders;
    :Archive artifacts;
  }
  
else (feature/bugfix)
  :Deploy to preview environment;
  :Run preview tests;
  :Notify developer;
  note right
    Preview URL available
    for testing
  end note
endif

|Monitoring|
:Start monitoring;
fork
  :Application metrics;
  note right
    - Response times
    - Error rates
    - Throughput
  end note
fork again
  :Infrastructure metrics;
  note right
    - CPU usage
    - Memory usage
    - Disk I/O
  end note
fork again
  :Business metrics;
  note right
    - Analysis count
    - User activity
    - API usage
  end note
end fork

:Send to Grafana;
:Configure alerts;

stop

note right of "Build Stage"
  Tools:
  - npm/yarn (Frontend)
  - pip/poetry (Backend)
  - Docker buildx
end note

note right of "Test Stage"
  Tools:
  - Jest (Frontend)
  - pytest (Backend)
  - Playwright (E2E)
  - Coverage.py
end note

note right of "Security Scan Stage"
  Fail on:
  - Critical vulnerabilities
  - High severity with exploit
  - Exposed secrets
end note

note right of "Deploy to Production"
  Deployment Strategy:
  - Blue-Green deployment
  - Canary releases (future)
  - Automatic rollback
  - Zero-downtime
end note

@enduml
