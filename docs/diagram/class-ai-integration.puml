@startuml Class Diagram - AI Integration
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - AI Integration Domain

' References from other domains
class Analysis {
  - id: UUID
  - status: AnalysisStatus
}

class Issue {
  - id: UUID
  - severity: Severity
}

class CodeEntity {
  - id: UUID
  - entityType: EntityType
}

' AI Integration Domain
package "AI Integration" {
  class AgenticAI {
    - llmClient: LLMClient
    - contextBuilder: ContextBuilder
    - promptManager: PromptManager
    - responseParser: ResponseParser
    --
    + analyzeCode(code: string, context: Context): AIAnalysis
    + generateReview(analysis: Analysis): ReviewComment[]
    + suggestFixes(issue: Issue): CodeSuggestion[]
    + detectPatterns(entities: CodeEntity[]): Pattern[]
    + explainCode(code: string): Explanation
    + generateTests(code: string): TestCase[]
    + refactorSuggestion(code: string): RefactoringSuggestion
  }

  class LLMClient {
    - apiKey: string
    - model: string
    - endpoint: string
    - maxTokens: number
    - temperature: number
    - timeout: number
    --
    + sendRequest(prompt: string, options: RequestOptions): LLMResponse
    + streamResponse(prompt: string): AsyncIterator<string>
    + validateResponse(response: LLMResponse): boolean
    + estimateTokens(text: string): number
    + checkRateLimit(): RateLimitInfo
    + retryWithBackoff(request: Request): LLMResponse
  }

  class ContextBuilder {
    - maxContextSize: number
    - priorityRules: PriorityRule[]
    --
    + buildCodeContext(pr: PullRequest): Context
    + buildArchitectureContext(project: Project): Context
    + addComplianceRules(standards: string[]): void
    + addProjectHistory(project: Project): void
    + addRelevantFiles(files: File[]): void
    + optimizeContext(context: Context): Context
    + estimateSize(context: Context): number
  }

  class PromptManager {
    - templates: Map<string, PromptTemplate>
    - variableResolver: VariableResolver
    --
    + getTemplate(name: string): PromptTemplate
    + renderPrompt(template: PromptTemplate, variables: Map<string, any>): string
    + createCustomPrompt(name: string, content: string): PromptTemplate
    + validatePrompt(prompt: string): ValidationResult
    + optimizePrompt(prompt: string): string
  }

  class ResponseParser {
    - schemas: Map<string, Schema>
    --
    + parse(response: LLMResponse, schema: Schema): ParsedResponse
    + extractIssues(response: LLMResponse): Issue[]
    + extractSuggestions(response: LLMResponse): CodeSuggestion[]
    + extractPatterns(response: LLMResponse): Pattern[]
    + validateStructure(response: LLMResponse): boolean
  }

  class EmbeddingService {
    - embeddingModel: string
    - vectorStore: VectorStore
    --
    + generateEmbedding(text: string): Vector
    + storeEmbedding(id: UUID, vector: Vector, metadata: Map<string, any>): void
    + searchSimilar(query: string, limit: number): SearchResult[]
    + findRelevantContext(query: string): Context
  }

  class VectorStore {
    - dimensions: number
    - indexType: string
    --
    + insert(id: UUID, vector: Vector, metadata: Map<string, any>): void
    + search(vector: Vector, limit: number): SearchResult[]
    + delete(id: UUID): void
    + update(id: UUID, vector: Vector): void
  }

  class RateLimiter {
    - requestsPerMinute: number
    - tokensPerMinute: number
    - currentRequests: number
    - currentTokens: number
    --
    + checkLimit(): boolean
    + consumeRequest(tokens: number): void
    + getRemainingQuota(): Quota
    + waitForAvailability(): Promise<void>
    + reset(): void
  }

  class CacheManager {
    - cache: Cache
    - ttl: number
    --
    + get(key: string): CachedResponse
    + set(key: string, value: any, ttl: number): void
    + invalidate(key: string): void
    + clear(): void
    + generateKey(prompt: string, options: RequestOptions): string
  }

  class TokenCounter {
    - encoding: string
    --
    + count(text: string): number
    + countMessages(messages: Message[]): number
    + estimateCost(tokens: number, model: string): number
    + truncate(text: string, maxTokens: number): string
  }
}

' DTOs and Models
package "DTOs" {
  class AIAnalysis {
    + issues: Issue[]
    + patterns: Pattern[]
    + suggestions: CodeSuggestion[]
    + qualityScore: number
    + confidence: number
    + processingTime: number
  }

  class ReviewComment {
    + filePath: string
    + lineNumber: number
    + content: string
    + severity: string
    + category: string
  }

  class CodeSuggestion {
    + issueId: UUID
    + originalCode: string
    + suggestedCode: string
    + explanation: string
    + confidence: number
  }

  class Pattern {
    + name: string
    + type: string
    + description: string
    + occurrences: Occurrence[]
    + recommendation: string
  }

  class Context {
    + code: string
    + files: File[]
    + history: Commit[]
    + complianceRules: Rule[]
    + projectMetadata: Map<string, any>
    + size: number
  }

  class LLMResponse {
    + content: string
    + model: string
    + tokensUsed: number
    + finishReason: string
    + metadata: Map<string, any>
  }

  class RequestOptions {
    + temperature: number
    + maxTokens: number
    + topP: number
    + frequencyPenalty: number
    + presencePenalty: number
    + stopSequences: string[]
  }

  class PromptTemplate {
    + name: string
    + content: string
    + variables: Set<string>
    + metadata: Map<string, any>
  }

  class ParsedResponse {
    + data: any
    + isValid: boolean
    + errors: string[]
  }

  class Vector {
    + dimensions: number
    + values: number[]
  }

  class SearchResult {
    + id: UUID
    + score: number
    + metadata: Map<string, any>
    + content: string
  }

  class RateLimitInfo {
    + requestsRemaining: number
    + tokensRemaining: number
    + resetAt: DateTime
  }

  class Quota {
    + requestsRemaining: number
    + tokensRemaining: number
  }

  class Explanation {
    + summary: string
    + details: string
    + complexity: string
    + purpose: string
  }

  class TestCase {
    + name: string
    + input: any
    + expectedOutput: any
    + description: string
  }

  class RefactoringSuggestion {
    + type: string
    + originalCode: string
    + refactoredCode: string
    + benefits: string[]
    + risks: string[]
  }
}

' Relationships
AgenticAI ..> LLMClient : uses
AgenticAI ..> ContextBuilder : uses
AgenticAI ..> PromptManager : uses
AgenticAI ..> ResponseParser : uses
AgenticAI ..> EmbeddingService : uses

LLMClient ..> RateLimiter : checks
LLMClient ..> CacheManager : uses
LLMClient ..> TokenCounter : uses
LLMClient ..> LLMResponse : returns
LLMClient ..> RequestOptions : accepts

ContextBuilder ..> Context : builds
PromptManager ..> PromptTemplate : manages
ResponseParser ..> ParsedResponse : creates
EmbeddingService ..> VectorStore : uses
EmbeddingService ..> Vector : generates

AgenticAI ..> AIAnalysis : generates
AgenticAI ..> ReviewComment : creates
AgenticAI ..> CodeSuggestion : generates
AgenticAI ..> Pattern : detects
AgenticAI ..> Explanation : provides
AgenticAI ..> TestCase : generates
AgenticAI ..> RefactoringSuggestion : creates

Analysis ..> AgenticAI : uses
Issue ..> AgenticAI : analyzed by
CodeEntity ..> AgenticAI : analyzed by

note right of AgenticAI
  Core AI orchestration
  - Code analysis with LLM
  - Review comment generation
  - Fix suggestions
  - Pattern detection
  - Code explanation
  - Test generation
  - Refactoring suggestions
end note

note right of LLMClient
  LLM API integration
  - Supports: OpenAI GPT-4, Claude, 
    Gemini, local models
  - Streaming responses
  - Rate limiting
  - Retry with exponential backoff
  - Response caching
  - Token estimation
end note

note right of ContextBuilder
  Context optimization
  - Max context: 128K tokens
  - Priority: changed files > related 
    files > project history
  - Compliance rules injection
  - Context size estimation
  - Intelligent truncation
end note

note right of EmbeddingService
  Semantic search
  - Generate embeddings for code
  - Store in vector database
  - Find similar code patterns
  - Retrieve relevant context
  - Model: text-embedding-3-large
end note

note right of PromptManager
  Prompt engineering
  - Template library
  - Variable substitution
  - Prompt optimization
  - Version control
  - A/B testing support
end note

@enduml
