@startuml Class Diagram - Architecture Analysis
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - Architecture Analysis Domain

' Reference to Project (from Project Management)
class Project {
  - id: UUID
  - name: string
}

' Architecture Analysis Domain
package "Architecture Analysis" {
  class CodeEntity {
    - id: UUID
    - projectId: UUID
    - entityType: EntityType
    - name: string
    - filePath: string
    - lineStart: number
    - lineEnd: number
    - complexity: number
    - linesOfCode: number
    - language: string
    - createdAt: DateTime
    - updatedAt: DateTime
    --
    + calculateComplexity(): number
    + getDependencies(): Dependency[]
    + getMetrics(): EntityMetrics
    + getChildren(): CodeEntity[]
    + getParent(): CodeEntity
    + isAbstract(): boolean
  }

  enum EntityType {
    MODULE
    CLASS
    INTERFACE
    FUNCTION
    METHOD
    --
    + isContainer(): boolean
    + canHaveChildren(): boolean
  }

  class Dependency {
    - id: UUID
    - sourceId: UUID
    - targetId: UUID
    - dependencyType: DependencyType
    - weight: number
    - strength: number
    - createdAt: DateTime
    - lastUpdated: DateTime
    --
    + isCircular(): boolean
    + getStrength(): number
    + calculateWeight(): number
    + getPath(): CodeEntity[]
  }

  enum DependencyType {
    IMPORT
    CALL
    INHERITANCE
    COMPOSITION
    AGGREGATION
    --
    + isCoupling(): boolean
    + getImpact(): number
  }

  class ArchitectureAnalyzer {
    - graphDatabase: Neo4jClient
    - astParser: ASTParser
    - entityRepository: EntityRepository
    - dependencyRepository: DependencyRepository
    --
    + parseSourceCode(files: File[]): CodeEntity[]
    + buildDependencyGraph(entities: CodeEntity[]): Graph
    + detectCircularDependencies(): Dependency[]
    + analyzeArchitecturalDrift(): DriftReport
    + visualizeGraph(): GraphVisualization
    + calculateCoupling(entity: CodeEntity): CouplingMetrics
    + detectLayerViolations(layers: Layer[]): Violation[]
  }

  class ASTParser {
    - supportedLanguages: Set<string>
    - parserRegistry: Map<string, Parser>
    --
    + parse(code: string, language: string): AST
    + extractEntities(ast: AST): CodeEntity[]
    + extractDependencies(ast: AST): Dependency[]
    + calculateMetrics(ast: AST): Metrics
    + detectPatterns(ast: AST): Pattern[]
  }

  class GraphBuilder {
    - neo4jClient: Neo4jClient
    --
    + createNode(entity: CodeEntity): Node
    + createRelationship(dependency: Dependency): Relationship
    + buildGraph(entities: CodeEntity[], dependencies: Dependency[]): Graph
    + updateGraph(changes: Change[]): void
    + queryGraph(cypher: string): QueryResult
  }

  class CircularDependencyDetector {
    - graph: Graph
    --
    + detect(): Dependency[][]
    + findCycles(): Cycle[]
    + calculateCycleComplexity(cycle: Cycle): number
    + suggestBreakpoints(cycle: Cycle): Breakpoint[]
  }

  class LayerAnalyzer {
    - layerDefinitions: Map<string, Layer>
    --
    + defineLayer(name: string, pattern: string): Layer
    + assignEntityToLayer(entity: CodeEntity): Layer
    + detectViolations(dependencies: Dependency[]): Violation[]
    + validateArchitecture(): ValidationReport
  }

  interface EntityRepository {
    + create(entity: CodeEntity): CodeEntity
    + findById(id: UUID): CodeEntity
    + findByProjectId(projectId: UUID): CodeEntity[]
    + findByType(projectId: UUID, type: EntityType): CodeEntity[]
    + update(entity: CodeEntity): CodeEntity
    + delete(id: UUID): void
  }

  interface DependencyRepository {
    + create(dependency: Dependency): Dependency
    + findById(id: UUID): Dependency
    + findBySourceId(sourceId: UUID): Dependency[]
    + findByTargetId(targetId: UUID): Dependency[]
    + findCircular(): Dependency[]
    + update(dependency: Dependency): Dependency
    + delete(id: UUID): void
  }
}

' DTOs and Models
package "DTOs" {
  class EntityMetrics {
    + complexity: number
    + linesOfCode: number
    + maintainabilityIndex: number
    + couplingFactor: number
    + cohesion: number
  }

  class CouplingMetrics {
    + afferentCoupling: number
    + efferentCoupling: number
    + instability: number
    + abstractness: number
  }

  class DriftReport {
    + projectId: UUID
    + analyzedAt: DateTime
    + newEntities: CodeEntity[]
    + removedEntities: CodeEntity[]
    + modifiedEntities: CodeEntity[]
    + newDependencies: Dependency[]
    + removedDependencies: Dependency[]
    + driftScore: number
  }

  class GraphVisualization {
    + nodes: Node[]
    + edges: Edge[]
    + layout: string
    + metadata: Map<string, any>
  }

  class Violation {
    + sourceLayer: string
    + targetLayer: string
    + dependency: Dependency
    + severity: string
    + description: string
  }

  class Layer {
    + name: string
    + pattern: string
    + allowedDependencies: Set<string>
    + entities: Set<CodeEntity>
  }

  class Cycle {
    + entities: CodeEntity[]
    + dependencies: Dependency[]
    + complexity: number
  }

  class Breakpoint {
    + dependency: Dependency
    + reason: string
    + impact: number
  }

  class ValidationReport {
    + isValid: boolean
    + violations: Violation[]
    + warnings: string[]
    + suggestions: string[]
  }

  class Graph {
    + nodes: Map<UUID, Node>
    + edges: Map<UUID, Edge>
    --
    + addNode(node: Node): void
    + addEdge(edge: Edge): void
    + findPath(from: UUID, to: UUID): Path
    + findCycles(): Cycle[]
  }

  class Node {
    + id: UUID
    + entity: CodeEntity
    + properties: Map<string, any>
  }

  class Edge {
    + id: UUID
    + dependency: Dependency
    + source: UUID
    + target: UUID
  }
}

' Relationships
Project "1" -- "0..*" CodeEntity : contains
CodeEntity "1" -- "1" EntityType : has
CodeEntity "0..*" -- "0..*" Dependency : depends on
Dependency "1" -- "1" DependencyType : has

ArchitectureAnalyzer ..> CodeEntity : creates
ArchitectureAnalyzer ..> Dependency : creates
ArchitectureAnalyzer ..> ASTParser : uses
ArchitectureAnalyzer ..> GraphBuilder : uses
ArchitectureAnalyzer ..> CircularDependencyDetector : uses
ArchitectureAnalyzer ..> LayerAnalyzer : uses
ArchitectureAnalyzer ..> EntityRepository : uses
ArchitectureAnalyzer ..> DependencyRepository : uses

GraphBuilder ..> Graph : builds
CircularDependencyDetector ..> Cycle : detects
LayerAnalyzer ..> Violation : detects
LayerAnalyzer ..> Layer : manages

CodeEntity ..> EntityMetrics : provides
ArchitectureAnalyzer ..> CouplingMetrics : calculates
ArchitectureAnalyzer ..> DriftReport : generates
ArchitectureAnalyzer ..> GraphVisualization : creates
LayerAnalyzer ..> ValidationReport : generates

note right of ArchitectureAnalyzer
  Core architecture analysis
  - Parse source code to entities
  - Build dependency graph in Neo4j
  - Detect circular dependencies
  - Analyze architectural drift
  - Calculate coupling metrics
  - Detect layer violations
end note

note right of CodeEntity
  Code structure representation
  - Types: module, class, interface, 
    function, method
  - Complexity calculation
  - Metrics: LOC, complexity, cohesion
  - Stored in Neo4j as nodes
end note

note right of Dependency
  Dependency relationships
  - Types: import, call, inheritance,
    composition, aggregation
  - Weight: usage frequency
  - Strength: coupling strength (1-10)
  - Stored in Neo4j as relationships
end note

note right of LayerAnalyzer
  Layered architecture validation
  - Define layers (presentation, 
    business, data, infrastructure)
  - Assign entities to layers
  - Detect layer violations
  - Enforce dependency rules
end note

note right of CircularDependencyDetector
  Circular dependency detection
  - Find all cycles in graph
  - Calculate cycle complexity
  - Suggest breakpoints
  - Tarjan's algorithm
end note

@enduml
