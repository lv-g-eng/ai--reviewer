@startuml Class Diagram - Code Analysis
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - Code Analysis Domain

' Reference to Project (from Project Management)
class Project {
  - id: UUID
  - name: string
}

' Code Analysis Domain
package "Code Analysis" {
  class PullRequest {
    - id: UUID
    - projectId: UUID
    - prNumber: number
    - githubPrId: string
    - title: string
    - author: string
    - sourceBranch: string
    - targetBranch: string
    - status: PRStatus
    - createdAt: DateTime
    - updatedAt: DateTime
    - closedAt: DateTime
    --
    + analyze(): Analysis
    + getChangedFiles(): File[]
    + postComment(comment: Comment): void
    + getStatus(): PRStatus
    + close(): void
    + merge(): void
  }

  enum PRStatus {
    OPEN
    CLOSED
    MERGED
    --
    + isActive(): boolean
  }

  class Analysis {
    - id: UUID
    - prId: UUID
    - status: AnalysisStatus
    - startedAt: DateTime
    - completedAt: DateTime
    - processingTime: number
    - totalIssues: number
    - criticalIssues: number
    - highIssues: number
    - mediumIssues: number
    - lowIssues: number
    - qualityScore: number
    - errorMessage: string
    --
    + start(): void
    + complete(): void
    + fail(error: Error): void
    + getIssuesBySeverity(severity: Severity): Issue[]
    + getIssuesByCategory(category: string): Issue[]
    + generateReport(): AnalysisReport
    + calculateQualityScore(): number
    + isPassingThreshold(threshold: number): boolean
  }

  enum AnalysisStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    --
    + isTerminal(): boolean
    + canRetry(): boolean
  }

  class Issue {
    - id: UUID
    - analysisId: UUID
    - severity: Severity
    - category: string
    - title: string
    - description: string
    - suggestion: string
    - filePath: string
    - lineNumber: number
    - codeSnippet: string
    - ruleId: string
    - createdAt: DateTime
    - userFeedback: string
    - feedbackComment: string
    - feedbackAt: DateTime
    --
    + toComment(): Comment
    + isCritical(): boolean
    + isBlocking(): boolean
    + applyFeedback(feedback: string, comment: string): void
    + getContext(): IssueContext
  }

  enum Severity {
    CRITICAL
    HIGH
    MEDIUM
    LOW
    --
    + getNumericValue(): number
    + isBlocker(): boolean
  }

  class Comment {
    - id: UUID
    - issueId: UUID
    - githubCommentId: string
    - content: string
    - postedAt: DateTime
    - status: CommentStatus
    --
    + post(): void
    + update(content: string): void
    + delete(): void
  }

  enum CommentStatus {
    PENDING
    POSTED
    FAILED
  }

  class CodeReviewEngine {
    - llmClient: LLMClient
    - parserService: ParserService
    - issueDetector: IssueDetector
    - contextBuilder: ContextBuilder
    - analysisRepository: AnalysisRepository
    --
    + analyzePR(pr: PullRequest): Analysis
    + detectIssues(code: string, language: string): Issue[]
    + generateSuggestions(issue: Issue): string
    + validateCode(code: string, rules: Set<string>): ValidationResult
    + compareWithBaseline(pr: PullRequest): ComparisonResult
  }

  class ParserService {
    - supportedLanguages: Set<string>
    - astParsers: Map<string, ASTParser>
    --
    + parse(code: string, language: string): AST
    + extractFunctions(ast: AST): Function[]
    + extractClasses(ast: AST): Class[]
    + calculateComplexity(ast: AST): number
    + detectLanguage(filePath: string): string
  }

  class IssueDetector {
    - rules: Map<string, Rule>
    - severityMapper: SeverityMapper
    --
    + detectAll(ast: AST, rules: Set<string>): Issue[]
    + detectByCategory(ast: AST, category: string): Issue[]
    + applyRule(ast: AST, rule: Rule): Issue[]
    + filterByThreshold(issues: Issue[], threshold: number): Issue[]
  }

  interface AnalysisRepository {
    + create(analysis: Analysis): Analysis
    + findById(id: UUID): Analysis
    + findByPRId(prId: UUID): Analysis[]
    + update(analysis: Analysis): Analysis
    + delete(id: UUID): void
  }

  interface IssueRepository {
    + create(issue: Issue): Issue
    + findById(id: UUID): Issue
    + findByAnalysisId(analysisId: UUID): Issue[]
    + findBySeverity(analysisId: UUID, severity: Severity): Issue[]
    + update(issue: Issue): Issue
    + delete(id: UUID): void
  }

  interface CommentRepository {
    + create(comment: Comment): Comment
    + findById(id: UUID): Comment
    + findByIssueId(issueId: UUID): Comment
    + update(comment: Comment): Comment
    + delete(id: UUID): void
  }
}

' DTOs
package "DTOs" {
  class AnalysisReport {
    + analysisId: UUID
    + prNumber: number
    + qualityScore: number
    + totalIssues: number
    + issuesBySeverity: Map<Severity, number>
    + issuesByCategory: Map<string, number>
    + processingTime: number
    + recommendations: string[]
  }

  class IssueContext {
    + filePath: string
    + lineNumber: number
    + codeSnippet: string
    + surroundingCode: string
    + language: string
  }

  class ValidationResult {
    + isValid: boolean
    + errors: string[]
    + warnings: string[]
  }

  class ComparisonResult {
    + newIssues: Issue[]
    + resolvedIssues: Issue[]
    + qualityScoreDelta: number
  }

  class File {
    + path: string
    + content: string
    + language: string
    + additions: number
    + deletions: number
  }
}

' Relationships
Project "1" -- "0..*" PullRequest : contains
PullRequest "1" -- "1" PRStatus : has
PullRequest "1" -- "0..*" Analysis : analyzed by
Analysis "1" -- "1" AnalysisStatus : has
Analysis "1" -- "0..*" Issue : identifies
Issue "1" -- "1" Severity : has
Issue "1" -- "0..1" Comment : generates
Comment "1" -- "1" CommentStatus : has

CodeReviewEngine ..> Analysis : creates
CodeReviewEngine ..> PullRequest : analyzes
CodeReviewEngine ..> ParserService : uses
CodeReviewEngine ..> IssueDetector : uses
CodeReviewEngine ..> AnalysisRepository : uses
ParserService ..> File : parses
IssueDetector ..> Issue : creates
IssueDetector ..> IssueRepository : uses
Comment ..> CommentRepository : persists

Analysis ..> AnalysisReport : generates
Issue ..> IssueContext : provides
ParserService ..> ValidationResult : returns
CodeReviewEngine ..> ComparisonResult : generates

note right of CodeReviewEngine
  Core analysis engine
  - Orchestrates PR analysis
  - Integrates LLM for AI review
  - Detects code issues
  - Generates suggestions
  - Compares with baseline
end note

note right of Analysis
  Analysis execution tracking
  - Status: pending → processing → completed/failed
  - Processing time tracking
  - Issue count by severity
  - Quality score (0-100)
  - Retry on failure (max 3 attempts)
end note

note right of Issue
  Detected code issues
  - Severity: critical, high, medium, low
  - Categories: security, performance, 
    maintainability, style, complexity
  - User feedback support
  - GitHub comment integration
end note

note right of ParserService
  Multi-language support:
  - Python (ast module)
  - JavaScript/TypeScript (babel)
  - Java (JavaParser)
  - Go (go/parser)
  - C++ (clang)
end note

@enduml
