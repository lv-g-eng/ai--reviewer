@startuml Class Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Quality Check Platform - Class Diagram

' User Management Domain
package "User Management" {
  class User {
    - id: UUID
    - username: string
    - email: string
    - passwordHash: string
    - role: UserRole
    - createdAt: DateTime
    - isActive: boolean
    --
    + authenticate(password: string): boolean
    + updateProfile(data: UserProfile): void
    + changePassword(oldPass: string, newPass: string): void
    + hasPermission(permission: string): boolean
  }

  enum UserRole {
    GUEST
    USER
    PROGRAMMER
    REVIEWER
    MANAGER
    ADMIN
  }

  class Session {
    - id: UUID
    - userId: UUID
    - token: string
    - expiresAt: DateTime
    --
    + isValid(): boolean
    + refresh(): void
    + revoke(): void
  }

  class AuthService {
    - jwtSecret: string
    - tokenExpiry: number
    --
    + register(userData: RegisterDTO): User
    + login(credentials: LoginDTO): Session
    + logout(token: string): void
    + validateToken(token: string): User
    + refreshToken(token: string): Session
  }
}

' Project Management Domain
package "Project Management" {
  class Project {
    - id: UUID
    - name: string
    - githubUrl: string
    - repositoryId: string
    - ownerId: UUID
    - defaultBranch: string
    - webhookSecret: string
    --
    + addMember(user: User, role: MemberRole): void
    + removeMember(userId: UUID): void
    + updateSettings(config: ProjectConfig): void
    + getMetrics(): QualityMetrics
  }

  class ProjectMember {
    - projectId: UUID
    - userId: UUID
    - role: MemberRole
    - joinedAt: DateTime
    --
    + updateRole(newRole: MemberRole): void
    + hasAccess(permission: string): boolean
  }

  enum MemberRole {
    OWNER
    MAINTAINER
    CONTRIBUTOR
    VIEWER
  }

  class ProjectService {
    - projectRepository: ProjectRepository
    - githubClient: GitHubClient
    --
    + createProject(data: CreateProjectDTO): Project
    + deleteProject(projectId: UUID): void
    + syncWithGitHub(projectId: UUID): void
    + configureWebhook(projectId: UUID): void
  }
}

' Code Analysis Domain
package "Code Analysis" {
  class PullRequest {
    - id: UUID
    - projectId: UUID
    - prNumber: number
    - title: string
    - author: string
    - status: PRStatus
    --
    + analyze(): Analysis
    + getChangedFiles(): File[]
    + postComment(comment: Comment): void
  }

  enum PRStatus {
    OPEN
    CLOSED
    MERGED
  }

  class Analysis {
    - id: UUID
    - prId: UUID
    - status: AnalysisStatus
    - startedAt: DateTime
    - completedAt: DateTime
    - issues: Issue[]
    --
    + start(): void
    + complete(): void
    + fail(error: Error): void
    + getIssuesBySeverity(severity: Severity): Issue[]
    + generateReport(): AnalysisReport
  }

  enum AnalysisStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
  }

  class Issue {
    - id: UUID
    - analysisId: UUID
    - filePath: string
    - lineNumber: number
    - severity: Severity
    - category: string
    - title: string
    - description: string
    - suggestion: string
    --
    + toComment(): Comment
    + isCritical(): boolean
  }

  enum Severity {
    CRITICAL
    HIGH
    MEDIUM
    LOW
  }

  class CodeReviewEngine {
    - llmClient: LLMClient
    - parserService: ParserService
    - issueDetector: IssueDetector
    --
    + analyzePR(pr: PullRequest): Analysis
    + detectIssues(code: string): Issue[]
    + generateSuggestions(issue: Issue): string
  }
}

' Architecture Analysis Domain
package "Architecture Analysis" {
  class CodeEntity {
    - id: UUID
    - projectId: UUID
    - entityType: EntityType
    - name: string
    - filePath: string
    - complexity: number
    --
    + calculateComplexity(): number
    + getDependencies(): Dependency[]
    + getMetrics(): EntityMetrics
  }

  enum EntityType {
    FILE
    CLASS
    FUNCTION
    METHOD
  }

  class Dependency {
    - id: UUID
    - sourceId: UUID
    - targetId: UUID
    - dependencyType: DependencyType
    - weight: number
    --
    + isCircular(): boolean
    + getStrength(): number
  }

  enum DependencyType {
    IMPORT
    CALL
    INHERITANCE
    COMPOSITION
  }

  class ArchitectureAnalyzer {
    - graphDatabase: Neo4jClient
    - astParser: ASTParser
    --
    + parseSourceCode(files: File[]): CodeEntity[]
    + buildDependencyGraph(entities: CodeEntity[]): Graph
    + detectCircularDependencies(): Dependency[]
    + analyzeArchitecturalDrift(): DriftReport
    + visualizeGraph(): GraphVisualization
  }

  class ASTParser {
    - supportedLanguages: string[]
    --
    + parse(code: string, language: string): AST
    + extractEntities(ast: AST): CodeEntity[]
    + extractDependencies(ast: AST): Dependency[]
  }
}

' AI Integration Domain
package "AI Integration" {
  class AgenticAI {
    - llmClient: LLMClient
    - contextBuilder: ContextBuilder
    --
    + analyzeCode(code: string, context: Context): AIAnalysis
    + generateReview(analysis: Analysis): ReviewComment[]
    + suggestFixes(issue: Issue): CodeSuggestion[]
    + detectPatterns(entities: CodeEntity[]): Pattern[]
  }

  class LLMClient {
    - apiKey: string
    - model: string
    - endpoint: string
    --
    + sendRequest(prompt: string): LLMResponse
    + streamResponse(prompt: string): AsyncIterator<string>
    + validateResponse(response: LLMResponse): boolean
  }

  class ContextBuilder {
    --
    + buildCodeContext(pr: PullRequest): Context
    + buildArchitectureContext(project: Project): Context
    + addComplianceRules(standards: string[]): void
  }
}

' Quality Metrics Domain
package "Quality Metrics" {
  class QualityMetric {
    - id: UUID
    - projectId: UUID
    - metricDate: Date
    - totalLines: number
    - codeCoverage: number
    - avgComplexity: number
    - technicalDebt: number
    --
    + calculate(): void
    + compare(other: QualityMetric): MetricDelta
    + getTrend(days: number): MetricTrend
  }

  class ComplianceCheck {
    - id: UUID
    - analysisId: UUID
    - standard: string
    - clause: string
    - status: ComplianceStatus
    --
    + verify(): boolean
    + getDetails(): string
  }

  enum ComplianceStatus {
    PASS
    FAIL
    WARNING
  }

  class MetricsService {
    - metricsRepository: MetricsRepository
    --
    + calculateMetrics(project: Project): QualityMetric
    + generateDashboard(projectId: UUID): Dashboard
    + exportReport(projectId: UUID, format: string): Report
    + trackTrends(projectId: UUID, period: Period): Trend[]
  }
}

' Infrastructure Domain
package "Infrastructure" {
  class GitHubClient {
    - token: string
    - apiUrl: string
    --
    + fetchPR(repoUrl: string, prNumber: number): PRData
    + postComment(prId: string, comment: Comment): void
    + configureWebhook(repoUrl: string, webhookUrl: string): void
    + fetchFiles(repoUrl: string, ref: string): File[]
  }

  class Neo4jClient {
    - uri: string
    - credentials: Credentials
    --
    + createNode(entity: CodeEntity): void
    + createRelationship(dependency: Dependency): void
    + query(cypher: string): QueryResult
    + findCircularDependencies(): Dependency[]
  }

  class RedisClient {
    - host: string
    - port: number
    --
    + enqueue(task: Task): void
    + dequeue(): Task
    + cache(key: string, value: any, ttl: number): void
    + get(key: string): any
  }

  class TaskQueue {
    - redisClient: RedisClient
    --
    + addTask(task: Task): void
    + processTask(taskId: UUID): void
    + getTaskStatus(taskId: UUID): TaskStatus
    + retryFailedTasks(): void
  }
}

' Relationships
User "1" -- "0..*" Session : has
User "1" -- "0..*" Project : owns
User "0..*" -- "0..*" Project : member of
(User, Project) .. ProjectMember

Project "1" -- "0..*" PullRequest : contains
PullRequest "1" -- "0..*" Analysis : analyzed by
Analysis "1" -- "0..*" Issue : identifies
Project "1" -- "0..*" CodeEntity : contains
CodeEntity "0..*" -- "0..*" Dependency : depends on

AuthService ..> User : manages
ProjectService ..> Project : manages
CodeReviewEngine ..> Analysis : creates
ArchitectureAnalyzer ..> CodeEntity : creates
ArchitectureAnalyzer ..> Dependency : creates
AgenticAI ..> LLMClient : uses
MetricsService ..> QualityMetric : calculates

CodeReviewEngine ..> GitHubClient : uses
ArchitectureAnalyzer ..> Neo4jClient : uses
CodeReviewEngine ..> TaskQueue : uses
TaskQueue ..> RedisClient : uses

@enduml
