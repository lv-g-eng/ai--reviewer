@startuml Class Diagram - Infrastructure
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - Infrastructure Domain

' Infrastructure Domain
package "Infrastructure" {
  class GitHubClient {
    - token: string
    - apiUrl: string
    - apiVersion: string
    - timeout: number
    - retryAttempts: number
    --
    + fetchPR(repoUrl: string, prNumber: number): PRData
    + fetchFiles(repoUrl: string, ref: string): File[]
    + postComment(prId: string, comment: Comment): void
    + updateComment(commentId: string, content: string): void
    + deleteComment(commentId: string): void
    + createWebhook(owner: string, repo: string, config: WebhookConfig): Webhook
    + deleteWebhook(owner: string, repo: string, webhookId: string): void
    + verifyAccess(owner: string, repo: string): boolean
    + getRepository(owner: string, repo: string): RepositoryInfo
    + listPullRequests(owner: string, repo: string, state: string): PRData[]
  }

  class Neo4jClient {
    - uri: string
    - username: string
    - password: string
    - database: string
    - maxConnectionPoolSize: number
    --
    + connect(): void
    + disconnect(): void
    + createNode(entity: CodeEntity): Node
    + createRelationship(dependency: Dependency): Relationship
    + query(cypher: string, parameters: Map<string, any>): QueryResult
    + findCircularDependencies(): Dependency[]
    + findPath(fromId: UUID, toId: UUID): Path
    + deleteNode(id: UUID): void
    + deleteRelationship(id: UUID): void
    + clearDatabase(): void
    + executeTransaction(operations: Operation[]): TransactionResult
  }

  class RedisClient {
    - host: string
    - port: number
    - password: string
    - database: number
    - maxRetries: number
    --
    + connect(): void
    + disconnect(): void
    + enqueue(queue: string, task: Task): void
    + dequeue(queue: string): Task
    + cache(key: string, value: any, ttl: number): void
    + get(key: string): any
    + delete(key: string): void
    + exists(key: string): boolean
    + increment(key: string): number
    + expire(key: string, seconds: number): void
    + publish(channel: string, message: string): void
    + subscribe(channel: string, callback: Function): void
  }

  class PostgreSQLClient {
    - host: string
    - port: number
    - database: string
    - username: string
    - password: string
    - maxConnections: number
    --
    + connect(): void
    + disconnect(): void
    + query(sql: string, parameters: any[]): QueryResult
    + execute(sql: string, parameters: any[]): ExecuteResult
    + beginTransaction(): Transaction
    + commit(transaction: Transaction): void
    + rollback(transaction: Transaction): void
    + getConnection(): Connection
    + releaseConnection(connection: Connection): void
  }

  class TaskQueue {
    - redisClient: RedisClient
    - queueName: string
    - maxRetries: number
    - retryDelay: number
    --
    + addTask(task: Task): void
    + processTask(taskId: UUID): void
    + getTaskStatus(taskId: UUID): TaskStatus
    + retryFailedTasks(): void
    + cancelTask(taskId: UUID): void
    + getQueueSize(): number
    + clearQueue(): void
    + pauseQueue(): void
    + resumeQueue(): void
  }

  class EmailService {
    - smtpHost: string
    - smtpPort: number
    - username: string
    - password: string
    - fromAddress: string
    --
    + sendEmail(to: string, subject: string, body: string): void
    + sendTemplateEmail(to: string, template: string, data: Map<string, any>): void
    + sendBulkEmail(recipients: string[], subject: string, body: string): void
    + verifyConnection(): boolean
  }

  class LoggerService {
    - logLevel: string
    - logFormat: string
    - outputPath: string
    --
    + debug(message: string, context: Map<string, any>): void
    + info(message: string, context: Map<string, any>): void
    + warn(message: string, context: Map<string, any>): void
    + error(message: string, error: Error, context: Map<string, any>): void
    + fatal(message: string, error: Error, context: Map<string, any>): void
    + setLogLevel(level: string): void
  }

  class MonitoringService {
    - metricsEndpoint: string
    - alertEndpoint: string
    --
    + recordMetric(name: string, value: number, tags: Map<string, string>): void
    + recordDuration(name: string, duration: number): void
    + incrementCounter(name: string): void
    + sendAlert(severity: string, message: string, details: Map<string, any>): void
    + healthCheck(): HealthStatus
  }

  class CacheService {
    - redisClient: RedisClient
    - defaultTTL: number
    --
    + get(key: string): any
    + set(key: string, value: any, ttl: number): void
    + delete(key: string): void
    + clear(): void
    + has(key: string): boolean
    + getOrSet(key: string, factory: Function, ttl: number): any
    + invalidatePattern(pattern: string): void
  }

  class FileStorageService {
    - storageType: string
    - basePath: string
    - maxFileSize: number
    --
    + upload(file: File, path: string): string
    + download(path: string): File
    + delete(path: string): void
    + exists(path: string): boolean
    + getUrl(path: string): string
    + listFiles(directory: string): string[]
  }

  class WebhookHandler {
    - secretValidator: SecretValidator
    - eventHandlers: Map<string, EventHandler>
    --
    + handleWebhook(payload: string, signature: string, secret: string): void
    + registerHandler(event: string, handler: EventHandler): void
    + validateSignature(payload: string, signature: string, secret: string): boolean
    + parsePayload(payload: string): WebhookEvent
  }

  class RateLimiter {
    - redisClient: RedisClient
    - windowSize: number
    - maxRequests: number
    --
    + checkLimit(key: string): boolean
    + consumeRequest(key: string): void
    + getRemainingRequests(key: string): number
    + resetLimit(key: string): void
  }

  class ConfigurationManager {
    - configPath: string
    - environment: string
    - config: Map<string, any>
    --
    + load(): void
    + get(key: string): any
    + set(key: string, value: any): void
    + reload(): void
    + validate(): ValidationResult
  }
}

' DTOs and Models
package "DTOs" {
  class PRData {
    + id: string
    + number: number
    + title: string
    + author: string
    + sourceBranch: string
    + targetBranch: string
    + status: string
    + files: File[]
  }

  class File {
    + path: string
    + content: string
    + language: string
    + additions: number
    + deletions: number
  }

  class WebhookConfig {
    + url: string
    + secret: string
    + events: Set<string>
    + active: boolean
  }

  class Webhook {
    + id: string
    + url: string
    + events: Set<string>
    + active: boolean
  }

  class RepositoryInfo {
    + id: string
    + name: string
    + fullName: string
    + owner: string
    + defaultBranch: string
    + language: string
    + isPrivate: boolean
  }

  class Node {
    + id: UUID
    + labels: Set<string>
    + properties: Map<string, any>
  }

  class Relationship {
    + id: UUID
    + type: string
    + startNodeId: UUID
    + endNodeId: UUID
    + properties: Map<string, any>
  }

  class QueryResult {
    + records: Record[]
    + summary: Summary
  }

  class Task {
    + id: UUID
    + type: string
    + payload: Map<string, any>
    + status: TaskStatus
    + priority: number
    + createdAt: DateTime
    + retryCount: number
  }

  enum TaskStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
    CANCELLED
  }

  class TransactionResult {
    + success: boolean
    + results: any[]
    + error: Error
  }

  class Connection {
    + id: string
    + isActive: boolean
  }

  class Transaction {
    + id: string
    + startedAt: DateTime
  }

  class ExecuteResult {
    + rowsAffected: number
    + insertId: any
  }

  class HealthStatus {
    + status: string
    + services: Map<string, ServiceStatus>
    + timestamp: DateTime
  }

  class ServiceStatus {
    + name: string
    + status: string
    + latency: number
    + error: string
  }

  class WebhookEvent {
    + event: string
    + action: string
    + payload: Map<string, any>
    + timestamp: DateTime
  }

  class EventHandler {
    + handle(event: WebhookEvent): void
  }

  class Path {
    + nodes: Node[]
    + relationships: Relationship[]
    + length: number
  }

  class Operation {
    + type: string
    + query: string
    + parameters: Map<string, any>
  }

  class Record {
    + fields: Map<string, any>
  }

  class Summary {
    + queryType: string
    + counters: Map<string, number>
    + executionTime: number
  }
}

' Relationships
GitHubClient ..> PRData : fetches
GitHubClient ..> File : fetches
GitHubClient ..> WebhookConfig : uses
GitHubClient ..> Webhook : manages
GitHubClient ..> RepositoryInfo : returns

Neo4jClient ..> Node : creates
Neo4jClient ..> Relationship : creates
Neo4jClient ..> QueryResult : returns
Neo4jClient ..> Path : finds
Neo4jClient ..> TransactionResult : returns

RedisClient ..> Task : manages
TaskQueue ..> RedisClient : uses
TaskQueue ..> Task : processes
TaskQueue ..> TaskStatus : tracks

PostgreSQLClient ..> Connection : manages
PostgreSQLClient ..> Transaction : manages
PostgreSQLClient ..> QueryResult : returns
PostgreSQLClient ..> ExecuteResult : returns

CacheService ..> RedisClient : uses
WebhookHandler ..> WebhookEvent : processes
WebhookHandler ..> EventHandler : uses
RateLimiter ..> RedisClient : uses
MonitoringService ..> HealthStatus : provides

note right of GitHubClient
  GitHub API integration
  - REST API v3
  - GraphQL API v4
  - Webhook management
  - Rate limiting: 5000 req/hour
  - Retry with exponential backoff
  - OAuth token authentication
end note

note right of Neo4jClient
  Neo4j graph database
  - Cypher query language
  - ACID transactions
  - Connection pooling
  - Circular dependency detection
  - Path finding algorithms
  - Bolt protocol
end note

note right of RedisClient
  Redis in-memory store
  - Task queue (Bull/BullMQ)
  - Caching layer
  - Pub/Sub messaging
  - Rate limiting
  - Session storage
  - Distributed locks
end note

note right of PostgreSQLClient
  PostgreSQL database
  - Primary data store
  - ACID transactions
  - Connection pooling (pg-pool)
  - Prepared statements
  - Query optimization
  - Backup and replication
end note

note right of TaskQueue
  Asynchronous task processing
  - Priority queue
  - Retry mechanism (max 3)
  - Dead letter queue
  - Task scheduling
  - Concurrency control
  - Progress tracking
end note

note right of MonitoringService
  System monitoring
  - Prometheus metrics
  - Grafana dashboards
  - Alert notifications
  - Health checks
  - Performance tracking
  - Error tracking (Sentry)
end note

@enduml
