@startuml Class Diagram - Project Management
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - Project Management Domain

' Reference to User (from User Management)
class User {
  - id: UUID
  - username: string
  - role: UserRole
}

' Project Management Domain
package "Project Management" {
  class Project {
    - id: UUID
    - name: string
    - githubUrl: string
    - repositoryId: string
    - ownerId: UUID
    - defaultBranch: string
    - webhookSecret: string
    - isActive: boolean
    - createdAt: DateTime
    - updatedAt: DateTime
    - lastAnalyzed: DateTime
    --
    + addMember(user: User, role: MemberRole): void
    + removeMember(userId: UUID): void
    + updateSettings(config: ProjectConfig): void
    + getMetrics(): QualityMetrics
    + activate(): void
    + deactivate(): void
    + syncWithGitHub(): void
  }

  class ProjectMember {
    - id: UUID
    - projectId: UUID
    - userId: UUID
    - role: MemberRole
    - joinedAt: DateTime
    --
    + updateRole(newRole: MemberRole): void
    + hasAccess(permission: string): boolean
    + canWrite(): boolean
    + canAdmin(): boolean
  }

  enum MemberRole {
    OWNER
    MAINTAINER
    CONTRIBUTOR
    VIEWER
    --
    + getPermissions(): Set<string>
    + canManageMembers(): boolean
  }

  class ProjectService {
    - projectRepository: ProjectRepository
    - githubClient: GitHubClient
    - webhookService: WebhookService
    --
    + createProject(data: CreateProjectDTO): Project
    + deleteProject(projectId: UUID): void
    + updateProject(projectId: UUID, data: UpdateProjectDTO): Project
    + syncWithGitHub(projectId: UUID): void
    + configureWebhook(projectId: UUID): void
    + getProjectMembers(projectId: UUID): ProjectMember[]
    + addMember(projectId: UUID, userId: UUID, role: MemberRole): void
    + removeMember(projectId: UUID, userId: UUID): void
  }

  class WebhookService {
    - githubClient: GitHubClient
    - secretGenerator: SecretGenerator
    --
    + configure(project: Project): string
    + verify(signature: string, payload: string, secret: string): boolean
    + remove(project: Project): void
    + regenerateSecret(project: Project): string
  }

  class AnalysisConfig {
    - id: UUID
    - projectId: UUID
    - enabledRules: Set<string>
    - severityThresholds: Map<string, number>
    - complianceStandards: Set<string>
    - llmModel: string
    - autoMergeOnPass: boolean
    - createdAt: DateTime
    - updatedAt: DateTime
    --
    + updateRules(rules: Set<string>): void
    + setThreshold(severity: string, threshold: number): void
    + enableStandard(standard: string): void
    + disableStandard(standard: string): void
  }

  class ConfigService {
    - configRepository: ConfigRepository
    --
    + getConfig(projectId: UUID): AnalysisConfig
    + updateConfig(projectId: UUID, config: AnalysisConfig): void
    + resetToDefaults(projectId: UUID): AnalysisConfig
    + validateConfig(config: AnalysisConfig): ValidationResult
  }

  interface ProjectRepository {
    + findById(id: UUID): Project
    + findByGithubUrl(url: string): Project
    + findByOwnerId(ownerId: UUID): Project[]
    + create(project: Project): Project
    + update(project: Project): Project
    + delete(id: UUID): void
    + exists(githubUrl: string): boolean
  }

  interface ConfigRepository {
    + findByProjectId(projectId: UUID): AnalysisConfig
    + create(config: AnalysisConfig): AnalysisConfig
    + update(config: AnalysisConfig): AnalysisConfig
    + delete(projectId: UUID): void
  }

  class GitHubClient {
    - token: string
    - apiUrl: string
    --
    + getRepository(owner: string, repo: string): RepositoryInfo
    + createWebhook(owner: string, repo: string, config: WebhookConfig): Webhook
    + deleteWebhook(owner: string, repo: string, webhookId: string): void
    + verifyAccess(owner: string, repo: string): boolean
  }
}

' DTOs
package "DTOs" {
  class CreateProjectDTO {
    + name: string
    + githubUrl: string
    + defaultBranch: string
  }

  class UpdateProjectDTO {
    + name: string
    + defaultBranch: string
    + isActive: boolean
  }

  class ProjectConfig {
    + enabledRules: Set<string>
    + severityThresholds: Map<string, number>
    + complianceStandards: Set<string>
  }

  class QualityMetrics {
    + qualityScore: number
    + totalIssues: number
    + criticalIssues: number
    + technicalDebt: number
  }

  class RepositoryInfo {
    + id: string
    + name: string
    + fullName: string
    + defaultBranch: string
    + language: string
  }

  class WebhookConfig {
    + url: string
    + secret: string
    + events: Set<string>
  }
}

' Relationships
User "1" -- "0..*" Project : owns
User "0..*" -- "0..*" Project : member of
(User, Project) .. ProjectMember

Project "1" -- "0..*" ProjectMember : has
Project "1" -- "1" AnalysisConfig : configured by
ProjectService ..> Project : manages
ProjectService ..> ProjectRepository : uses
ProjectService ..> GitHubClient : uses
ProjectService ..> WebhookService : uses
WebhookService ..> GitHubClient : uses
ConfigService ..> AnalysisConfig : manages
ConfigService ..> ConfigRepository : uses

ProjectService ..> CreateProjectDTO : accepts
ProjectService ..> UpdateProjectDTO : accepts
Project ..> QualityMetrics : provides
GitHubClient ..> RepositoryInfo : returns
WebhookService ..> WebhookConfig : uses

note right of Project
  GitHub repository integration
  - Unique GitHub URL
  - Webhook configuration
  - Active/inactive status
  - Last analysis timestamp
end note

note right of ProjectMember
  Team collaboration
  - Role-based permissions
  - Owner: Full control
  - Maintainer: Manage settings
  - Contributor: Submit code
  - Viewer: Read-only access
end note

note right of AnalysisConfig
  Project-specific settings
  - Enabled analysis rules
  - Severity thresholds
  - Compliance standards (ISO/IEC)
  - LLM model selection
  - Auto-merge configuration
end note

@enduml
