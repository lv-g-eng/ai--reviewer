@startuml Class Diagram - Quality Metrics
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - Quality Metrics Domain

' References from other domains
class Project {
  - id: UUID
  - name: string
}

class Analysis {
  - id: UUID
  - qualityScore: number
}

' Quality Metrics Domain
package "Quality Metrics" {
  class QualityMetric {
    - id: UUID
    - projectId: UUID
    - metricDate: Date
    - totalLines: number
    - codeCoverage: number
    - avgComplexity: number
    - technicalDebt: number
    - maintainabilityIndex: number
    - duplicateCodePercentage: number
    - testCoverage: number
    - documentationCoverage: number
    - createdAt: DateTime
    --
    + calculate(): void
    + compare(other: QualityMetric): MetricDelta
    + getTrend(days: number): MetricTrend
    + isImproving(): boolean
    + getScore(): number
    + toJSON(): string
  }

  class ComplianceCheck {
    - id: UUID
    - analysisId: UUID
    - standard: string
    - clause: string
    - status: ComplianceStatus
    - details: string
    - checkedAt: DateTime
    --
    + verify(): boolean
    + getDetails(): string
    + updateStatus(status: ComplianceStatus): void
    + generateReport(): ComplianceReport
  }

  enum ComplianceStatus {
    PASS
    FAIL
    WARNING
    NOT_APPLICABLE
    --
    + isCompliant(): boolean
    + requiresAction(): boolean
  }

  class MetricsService {
    - metricsRepository: MetricsRepository
    - calculatorRegistry: Map<string, MetricCalculator>
    - aggregator: MetricsAggregator
    --
    + calculateMetrics(project: Project): QualityMetric
    + generateDashboard(projectId: UUID): Dashboard
    + exportReport(projectId: UUID, format: string): Report
    + trackTrends(projectId: UUID, period: Period): Trend[]
    + compareProjects(projectIds: UUID[]): ComparisonReport
    + scheduleCalculation(projectId: UUID, schedule: Schedule): void
  }

  class MetricCalculator {
    - metricType: string
    --
    + calculate(project: Project): number
    + validate(value: number): boolean
    + normalize(value: number): number
  }

  class ComplexityCalculator {
    --
    + calculateCyclomaticComplexity(code: string): number
    + calculateCognitiveComplexity(code: string): number
    + calculateHalsteadMetrics(code: string): HalsteadMetrics
    + calculateMaintainabilityIndex(metrics: Metrics): number
  }

  class CoverageCalculator {
    --
    + calculateCodeCoverage(project: Project): number
    + calculateTestCoverage(project: Project): number
    + calculateBranchCoverage(project: Project): number
    + calculateDocumentationCoverage(project: Project): number
  }

  class TechnicalDebtCalculator {
    - debtRules: Map<string, DebtRule>
    --
    + calculateDebt(project: Project): number
    + estimateRemediationTime(debt: number): number
    + prioritizeDebt(issues: Issue[]): Issue[]
    + calculateDebtRatio(debt: number, totalLines: number): number
  }

  class MetricsAggregator {
    --
    + aggregateByPeriod(metrics: QualityMetric[], period: Period): AggregatedMetrics
    + calculateAverage(metrics: QualityMetric[]): QualityMetric
    + calculateMedian(metrics: QualityMetric[]): QualityMetric
    + calculatePercentile(metrics: QualityMetric[], percentile: number): QualityMetric
  }

  class TrendAnalyzer {
    --
    + analyzeTrend(metrics: QualityMetric[]): Trend
    + predictFuture(metrics: QualityMetric[], days: number): Prediction
    + detectAnomalies(metrics: QualityMetric[]): Anomaly[]
    + calculateVelocity(metrics: QualityMetric[]): number
  }

  class DashboardBuilder {
    - widgets: Map<string, Widget>
    --
    + buildDashboard(project: Project): Dashboard
    + addWidget(widget: Widget): void
    + removeWidget(widgetId: string): void
    + customizeLayout(layout: Layout): void
  }

  interface MetricsRepository {
    + create(metric: QualityMetric): QualityMetric
    + findById(id: UUID): QualityMetric
    + findByProjectId(projectId: UUID): QualityMetric[]
    + findByDateRange(projectId: UUID, start: Date, end: Date): QualityMetric[]
    + findLatest(projectId: UUID): QualityMetric
    + update(metric: QualityMetric): QualityMetric
    + delete(id: UUID): void
  }

  interface ComplianceRepository {
    + create(check: ComplianceCheck): ComplianceCheck
    + findById(id: UUID): ComplianceCheck
    + findByAnalysisId(analysisId: UUID): ComplianceCheck[]
    + findByStandard(analysisId: UUID, standard: string): ComplianceCheck[]
    + update(check: ComplianceCheck): ComplianceCheck
    + delete(id: UUID): void
  }
}

' DTOs and Models
package "DTOs" {
  class MetricDelta {
    + totalLinesDelta: number
    + codeCoverageDelta: number
    + complexityDelta: number
    + technicalDebtDelta: number
    + overallChange: number
  }

  class MetricTrend {
    + metric: string
    + values: number[]
    + dates: Date[]
    + direction: string
    + changeRate: number
  }

  class Dashboard {
    + projectId: UUID
    + widgets: Widget[]
    + layout: Layout
    + lastUpdated: DateTime
  }

  class Widget {
    + id: string
    + type: string
    + title: string
    + data: any
    + position: Position
  }

  class Report {
    + projectId: UUID
    + format: string
    + content: string
    + generatedAt: DateTime
    + metadata: Map<string, any>
  }

  class Trend {
    + direction: string
    + slope: number
    + confidence: number
    + dataPoints: number
  }

  class ComparisonReport {
    + projects: Project[]
    + metrics: Map<UUID, QualityMetric>
    + rankings: Ranking[]
    + insights: string[]
  }

  class Period {
    + start: Date
    + end: Date
    + interval: string
  }

  class HalsteadMetrics {
    + volume: number
    + difficulty: number
    + effort: number
    + time: number
    + bugs: number
  }

  class AggregatedMetrics {
    + period: Period
    + average: QualityMetric
    + median: QualityMetric
    + min: QualityMetric
    + max: QualityMetric
  }

  class Prediction {
    + date: Date
    + predictedValue: number
    + confidence: number
    + range: Range
  }

  class Anomaly {
    + date: Date
    + metric: string
    + value: number
    + expectedValue: number
    + deviation: number
  }

  class ComplianceReport {
    + analysisId: UUID
    + standard: string
    + totalChecks: number
    + passed: number
    + failed: number
    + warnings: number
    + complianceRate: number
    + details: ComplianceCheck[]
  }

  class DebtRule {
    + ruleId: string
    + severity: string
    + remediationTime: number
    + multiplier: number
  }

  class Schedule {
    + frequency: string
    + time: string
    + timezone: string
  }

  class Layout {
    + columns: number
    + rows: number
    + gridSize: number
  }

  class Position {
    + x: number
    + y: number
    + width: number
    + height: number
  }

  class Ranking {
    + projectId: UUID
    + rank: number
    + score: number
  }

  class Range {
    + min: number
    + max: number
  }
}

' Relationships
Project "1" -- "0..*" QualityMetric : has
Analysis "1" -- "0..*" ComplianceCheck : verified by
QualityMetric "1" -- "1" Project : belongs to
ComplianceCheck "1" -- "1" ComplianceStatus : has

MetricsService ..> QualityMetric : calculates
MetricsService ..> MetricsRepository : uses
MetricsService ..> MetricCalculator : uses
MetricsService ..> MetricsAggregator : uses
MetricsService ..> TrendAnalyzer : uses
MetricsService ..> DashboardBuilder : uses

MetricCalculator <|-- ComplexityCalculator
MetricCalculator <|-- CoverageCalculator
MetricCalculator <|-- TechnicalDebtCalculator

ComplexityCalculator ..> HalsteadMetrics : calculates
TechnicalDebtCalculator ..> DebtRule : uses
MetricsAggregator ..> AggregatedMetrics : creates
TrendAnalyzer ..> Trend : analyzes
TrendAnalyzer ..> Prediction : generates
TrendAnalyzer ..> Anomaly : detects
DashboardBuilder ..> Dashboard : builds
DashboardBuilder ..> Widget : manages

QualityMetric ..> MetricDelta : compares
QualityMetric ..> MetricTrend : generates
MetricsService ..> Dashboard : generates
MetricsService ..> Report : exports
MetricsService ..> ComparisonReport : creates
ComplianceCheck ..> ComplianceReport : generates

note right of QualityMetric
  Daily quality snapshot
  - Total lines of code
  - Code coverage (%)
  - Average complexity
  - Technical debt (hours)
  - Maintainability index (0-100)
  - Duplicate code (%)
  - Test coverage (%)
  - Documentation coverage (%)
end note

note right of MetricsService
  Metrics orchestration
  - Calculate all metrics
  - Generate dashboards
  - Export reports (PDF, JSON, CSV)
  - Track trends over time
  - Compare projects
  - Schedule calculations
end note

note right of ComplianceCheck
  Standards verification
  - ISO/IEC 25010 (Quality model)
  - ISO/IEC 23396 (Code review)
  - Google Style Guides
  - OWASP Top 10
  - Custom standards
end note

note right of TechnicalDebtCalculator
  Technical debt estimation
  - SQALE methodology
  - Remediation time calculation
  - Debt ratio (debt/total LOC)
  - Priority ranking
  - Cost estimation
end note

note right of TrendAnalyzer
  Trend analysis
  - Linear regression
  - Moving averages
  - Anomaly detection
  - Future predictions
  - Velocity calculation
end note

@enduml
