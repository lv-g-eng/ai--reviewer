@startuml Class Diagram - User Management
!theme plain
skinparam backgroundColor #FFFFFF
skinparam classAttributeIconSize 0

title AI-Based Code Reviewer - User Management Domain

' User Management Domain
package "User Management" {
  class User {
    - id: UUID
    - username: string
    - email: string
    - passwordHash: string
    - role: UserRole
    - createdAt: DateTime
    - updatedAt: DateTime
    - lastLogin: DateTime
    - isActive: boolean
    - emailVerified: boolean
    - failedLoginAttempts: integer
    - lockedUntil: DateTime
    --
    + authenticate(password: string): boolean
    + updateProfile(data: UserProfile): void
    + changePassword(oldPass: string, newPass: string): void
    + hasPermission(permission: string): boolean
    + lockAccount(): void
    + unlockAccount(): void
    + verifyEmail(token: string): boolean
  }

  enum UserRole {
    GUEST
    USER
    PROGRAMMER
    REVIEWER
    MANAGER
    ADMIN
    --
    + hasPermission(permission: string): boolean
    + isHigherThan(role: UserRole): boolean
  }

  class Session {
    - id: UUID
    - userId: UUID
    - accessToken: string
    - refreshToken: string
    - expiresAt: DateTime
    - createdAt: DateTime
    - ipAddress: string
    - userAgent: string
    - isRevoked: boolean
    --
    + isValid(): boolean
    + refresh(): Session
    + revoke(): void
    + isExpired(): boolean
  }

  class AuthService {
    - tokenSecret: string
    - accessTokenExpiry: number
    - refreshTokenExpiry: number
    - userRepository: UserRepository
    - sessionRepository: SessionRepository
    --
    + register(userData: RegisterDTO): User
    + login(credentials: LoginDTO): Session
    + logout(token: string): void
    + validateToken(token: string): User
    + refreshToken(refreshToken: string): Session
    + resetPassword(email: string): void
    + changePassword(userId: UUID, oldPassword: string, newPassword: string): void
    + verifyEmail(token: string): boolean
  }

  class TokenManager {
    - secret: string
    - encryptionMethod: string
    --
    + generateAccessToken(user: User): string
    + generateRefreshToken(user: User): string
    + verifyToken(token: string): TokenPayload
    + decodeToken(token: string): TokenPayload
    + isTokenExpired(token: string): boolean
  }

  class PasswordHasher {
    - hashingRounds: integer
    --
    + hash(password: string): string
    + verify(password: string, hash: string): boolean
    + needsRehash(hash: string): boolean
  }

  class PermissionChecker {
    - permissionMatrix: Map<UserRole, Set<string>>
    --
    + hasPermission(user: User, permission: string): boolean
    + canAccessResource(user: User, resource: Resource): boolean
    + getPermissions(role: UserRole): Set<string>
  }

  interface UserRepository {
    + findById(id: UUID): User
    + findByEmail(email: string): User
    + findByUsername(username: string): User
    + create(user: User): User
    + update(user: User): User
    + delete(id: UUID): void
    + exists(email: string, username: string): boolean
  }

  interface SessionRepository {
    + create(session: Session): Session
    + findByToken(token: string): Session
    + findByUserId(userId: UUID): Session[]
    + revoke(token: string): void
    + revokeAll(userId: UUID): void
    + deleteExpired(): void
  }

  class AuditLogger {
    - auditRepository: AuditRepository
    --
    + logLogin(user: User, ipAddress: string): void
    + logLogout(user: User): void
    + logFailedLogin(email: string, ipAddress: string): void
    + logPasswordChange(user: User): void
    + logPermissionDenied(user: User, resource: string): void
  }
}

' DTOs
package "DTOs" {
  class RegisterDTO {
    + username: string
    + email: string
    + password: string
  }

  class LoginDTO {
    + email: string
    + password: string
  }

  class UserProfile {
    + username: string
    + email: string
  }

  class TokenPayload {
    + userId: UUID
    + email: string
    + role: UserRole
    + issuedAt: number
    + expiresAt: number
  }
}

' Relationships
User "1" -- "1" UserRole : has
User "1" -- "0..*" Session : has
AuthService ..> User : manages
AuthService ..> Session : creates
AuthService ..> UserRepository : uses
AuthService ..> SessionRepository : uses
AuthService ..> TokenManager : uses
AuthService ..> PasswordHasher : uses
AuthService ..> AuditLogger : uses
TokenManager ..> TokenPayload : creates
PermissionChecker ..> User : checks
PermissionChecker ..> UserRole : evaluates

AuthService ..> RegisterDTO : accepts
AuthService ..> LoginDTO : accepts
User ..> UserProfile : provides

note right of User
  Core user entity
  - Secure password hashing
  - Account lockout after 5 failed attempts
  - Email verification required
  - Role-based permissions
end note

note right of AuthService
  Authentication service
  - Token-based authentication
  - Access token: 24h expiry
  - Refresh token: 7d expiry
  - Password reset flow
end note

note right of PermissionChecker
  Permission matrix:
  - Guest: read public docs
  - User: read own projects
  - Programmer: write code
  - Reviewer: approve PRs
  - Manager: view all projects
  - Admin: full access
end note

@enduml
