@startuml Data Flow Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

title AI-Based Quality Check Platform - Data Flow Diagram

' External Entities
actor "Programmer" as programmer #LightBlue
actor "Reviewer" as reviewer #LightGreen
actor "Manager" as manager #LightYellow
actor "Administrator" as admin #LightCoral

' External Systems
cloud "GitHub" as github #LightGray
cloud "LLM API\n(GPT-4/Claude)" as llm #LightGray

' Main System Components
rectangle "Frontend\n(Next.js)" as frontend #SkyBlue
rectangle "API Gateway" as gateway #CornflowerBlue
rectangle "Auth Service" as auth #MediumPurple
rectangle "Code Review Engine" as review #Orange
rectangle "Architecture Analyzer" as analyzer #Coral
rectangle "Agentic AI" as ai #Gold
rectangle "Project Manager" as pm #LightSalmon

' Data Stores
database "PostgreSQL\n(User Data, Projects)" as postgres #LightSteelBlue
database "Neo4j\n(Dependency Graph)" as neo4j #LightPink
database "Redis\n(Cache, Queue)" as redis #LightCyan

' User Interactions
programmer --> frontend : Submit PR
reviewer --> frontend : View Analysis
manager --> frontend : View Dashboard
admin --> frontend : Configure System

' Frontend to Gateway
frontend --> gateway : API Requests\n(JWT Token)
gateway --> frontend : API Responses

' Authentication Flow
gateway --> auth : Authenticate User
auth --> postgres : Verify Credentials
postgres --> auth : User Data
auth --> gateway : JWT Token

' GitHub Webhook Flow
github --> gateway : PR Webhook Event\n(JSON Payload)
gateway --> review : Trigger Analysis
review --> github : Fetch PR Code
github --> review : Source Code

' Code Analysis Flow
review --> analyzer : Parse Source Code
analyzer --> analyzer : Generate AST
analyzer --> neo4j : Store Dependencies
neo4j --> analyzer : Graph Data
analyzer --> review : Dependency Info

' AI Analysis Flow
review --> ai : Code + Context
ai --> llm : Analysis Request
llm --> ai : AI Feedback
ai --> review : Structured Results

' Task Queue Flow
review --> redis : Queue Analysis Task
redis --> review : Task Status

' Post Results Flow
review --> github : Post PR Comments
review --> postgres : Store Analysis Results

' Dashboard Flow
gateway --> pm : Request Metrics
pm --> postgres : Query Projects
pm --> neo4j : Query Architecture
postgres --> pm : Quality Metrics
neo4j --> pm : Graph Metrics
pm --> gateway : Dashboard Data

' Admin Configuration
gateway --> pm : Update Config
pm --> postgres : Store Settings

' Legend
legend right
  |= Flow Type |= Description |
  | User Input | User interactions with system |
  | API Call | Internal service communication |
  | External API | Third-party service calls |
  | Data Storage | Database operations |
endlegend

@enduml
