@startuml Deployment Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

title AI-Based Code Reviewer - AWS Deployment Architecture

cloud "Internet" {
  actor "Users" as users
  actor "GitHub\nWebhooks" as github
}

package "AWS Cloud - us-east-1 (Primary Region)" {
  
  ' DNS and CDN Layer
  package "Edge Layer" {
    component "Route 53\n(DNS)" as route53 #LightBlue
    component "CloudFront\n(CDN)" as cloudfront #LightBlue {
      [Static Assets]
      [DDoS Protection]
    }
  }
  
  ' Load Balancer
  package "Load Balancing" {
    component "Application\nLoad Balancer" as alb #LightGreen {
      [SSL Termination]
      [Health Checks]
      [Target Groups]
    }
  }
  
  ' Kubernetes Cluster
  package "EKS Cluster (Kubernetes 1.28+)" {
    
    ' Frontend Pods
    package "Frontend Namespace" {
      node "Frontend Pod 1" as fe1 #SkyBlue {
        [Next.js App]
        [Nginx]
      }
      node "Frontend Pod 2" as fe2 #SkyBlue {
        [Next.js App]
        [Nginx]
      }
      node "Frontend Pod N" as feN #SkyBlue {
        [Next.js App]
        [Nginx]
      }
    }
    
    ' API Services Pods
    package "API Namespace" {
      node "Auth Service\nPod" as auth #LightGreen {
        [FastAPI]
        [Gunicorn]
      }
      node "Project Manager\nPod" as pm #LightGreen {
        [FastAPI]
        [Gunicorn]
      }
      node "Analysis Service\nPod" as analysis #LightGreen {
        [FastAPI]
        [Gunicorn]
      }
      node "Webhook Handler\nPod" as webhook #LightGreen {
        [FastAPI]
        [Gunicorn]
      }
      node "Metrics Service\nPod" as metrics #LightGreen {
        [FastAPI]
        [Gunicorn]
      }
    }
    
    ' Worker Pods
    package "Worker Namespace" {
      node "Code Review\nWorker Pod 1" as worker1 #Orange {
        [Celery Worker]
        [AST Parser]
      }
      node "Code Review\nWorker Pod 2" as worker2 #Orange {
        [Celery Worker]
        [AST Parser]
      }
      node "Architecture\nAnalyzer Pod" as arch_worker #Orange {
        [Celery Worker]
        [Graph Analyzer]
      }
      node "Agentic AI\nWorker Pod" as ai_worker #Orange {
        [Celery Worker]
        [LLM Client]
      }
    }
    
    ' Ingress Controller
    component "Ingress\nController" as ingress #LightYellow {
      [Nginx Ingress]
      [TLS Certificates]
    }
  }
  
  ' Data Layer
  package "Data Layer" {
    database "RDS PostgreSQL\n(Multi-AZ)" as rds #LightSteelBlue {
      [Primary Instance]
      [Read Replica]
      [Automated Backups]
    }
    
    database "ElastiCache\nRedis Cluster" as elasticache #LightCyan {
      [Primary Node]
      [Replica Nodes]
      [Cluster Mode]
    }
    
    node "EC2 Instance\n(Neo4j)" as neo4j_ec2 #LightPink {
      database "Neo4j\nGraph Database" as neo4j {
        [Graph Data]
        [Causal Cluster]
      }
    }
  }
  
  ' Storage
  package "Storage" {
    storage "S3 Buckets" as s3 #LightGoldenRodYellow {
      [Static Assets]
      [Backups]
      [Logs Archive]
    }
    
    storage "EBS Volumes" as ebs #LightGoldenRodYellow {
      [Database Storage]
      [Persistent Volumes]
    }
  }
  
  ' Monitoring and Logging
  package "Observability" {
    component "CloudWatch" as cloudwatch #LightCoral {
      [Logs]
      [Metrics]
      [Alarms]
    }
    
    node "Monitoring Stack" as monitoring #LightCoral {
      [Prometheus]
      [Grafana]
      [Jaeger]
    }
    
    node "ELK Stack" as elk #LightCoral {
      [Elasticsearch]
      [Logstash]
      [Kibana]
    }
  }
  
  ' Security
  package "Security Services" {
    component "AWS Secrets\nManager" as secrets #LightPink {
      [API Keys]
      [DB Credentials]
      [Certificates]
    }
    
    component "AWS KMS" as kms #LightPink {
      [Encryption Keys]
      [Key Rotation]
    }
    
    component "IAM" as iam #LightPink {
      [Roles]
      [Policies]
      [Service Accounts]
    }
  }
  
  ' VPC
  package "VPC (10.0.0.0/16)" {
    package "Public Subnets" {
      [ALB]
      [NAT Gateway]
    }
    
    package "Private Subnets" {
      [EKS Nodes]
      [RDS]
      [ElastiCache]
      [Neo4j]
    }
    
    component "Security Groups" as sg {
      [ALB SG]
      [EKS SG]
      [RDS SG]
      [Redis SG]
    }
  }
}

' External Services
cloud "External Services" {
  component "GitHub API" as github_api #LightGray
  component "OpenAI API" as openai #LightGray
  component "Anthropic API" as anthropic #LightGray
}

' Disaster Recovery Region
package "AWS Cloud - eu-west-1 (DR Region)" {
  database "RDS Read\nReplica" as rds_dr #LightSteelBlue
  storage "S3 Cross-Region\nReplication" as s3_dr #LightGoldenRodYellow
}

' Connections - User Flow
users --> route53 : DNS Query
route53 --> cloudfront : Route Traffic
cloudfront --> alb : HTTPS
alb --> ingress : Forward
ingress --> fe1 : Route
ingress --> fe2 : Route
ingress --> feN : Route

' API Connections
fe1 --> ingress : API Calls
ingress --> auth : /api/auth/*
ingress --> pm : /api/repositories/*
ingress --> analysis : /api/analyses/*
ingress --> webhook : /api/webhooks/*
ingress --> metrics : /api/metrics/*

' GitHub Webhook
github --> alb : Webhook Events
alb --> webhook : Forward

' Worker Connections
auth --> rds : User Data
auth --> elasticache : Sessions
pm --> rds : Projects
analysis --> rds : Results
analysis --> elasticache : Queue Tasks

worker1 --> elasticache : Dequeue
worker2 --> elasticache : Dequeue
arch_worker --> neo4j : Graph Ops
ai_worker --> openai : LLM Requests
ai_worker --> anthropic : Fallback

worker1 --> rds : Store Results
worker1 --> neo4j : Update Graph
worker1 --> github_api : Post Comments

' Storage Connections
fe1 ..> s3 : Static Assets
rds ..> s3 : Backups
rds ..> ebs : Storage
neo4j ..> ebs : Storage

' Monitoring
fe1 ..> cloudwatch : Logs
auth ..> cloudwatch : Logs
worker1 ..> cloudwatch : Logs
cloudwatch --> elk : Forward Logs
cloudwatch --> monitoring : Metrics

' Security
auth ..> secrets : Get Secrets
worker1 ..> secrets : Get API Keys
rds ..> kms : Encryption
s3 ..> kms : Encryption

' DR Replication
rds -.> rds_dr : Async Replication
s3 -.> s3_dr : Cross-Region Replication

note right of EKS
  Auto-scaling:
  - HPA: CPU/Memory based
  - Cluster Autoscaler
  - Min: 3 nodes
  - Max: 20 nodes
end note

note right of rds
  High Availability:
  - Multi-AZ deployment
  - Automated backups
  - Point-in-time recovery
  - Encryption at rest
end note

note right of elasticache
  Configuration:
  - Cluster mode enabled
  - 3 shards, 2 replicas
  - Automatic failover
  - In-transit encryption
end note

note bottom of VPC
  Network Security:
  - Private subnets for all data
  - NAT Gateway for outbound
  - Security Groups per service
  - Network ACLs
end note

@enduml
