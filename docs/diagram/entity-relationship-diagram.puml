@startuml Entity Relationship Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

title AI-Based Quality Check Platform - Entity Relationship Diagram

' User Management Entities
entity "User" as user {
  * id : UUID <<PK>>
  --
  * username : VARCHAR(50)
  * email : VARCHAR(100)
  * password_hash : VARCHAR(255)
  * role : ENUM(guest, user, programmer, reviewer, manager, admin)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  * last_login : TIMESTAMP
  is_active : BOOLEAN
}

entity "Session" as session {
  * id : UUID <<PK>>
  * user_id : UUID <<FK>>
  --
  * token : VARCHAR(500)
  * expires_at : TIMESTAMP
  * created_at : TIMESTAMP
  ip_address : VARCHAR(45)
  user_agent : TEXT
}

' Project Management Entities
entity "Project" as project {
  * id : UUID <<PK>>
  * owner_id : UUID <<FK>>
  --
  * name : VARCHAR(200)
  * github_url : VARCHAR(500)
  * repository_id : VARCHAR(100)
  * default_branch : VARCHAR(100)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  * last_analyzed : TIMESTAMP
  is_active : BOOLEAN
  webhook_secret : VARCHAR(255)
}

entity "ProjectMember" as member {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  * user_id : UUID <<FK>>
  --
  * role : ENUM(owner, maintainer, contributor, viewer)
  * joined_at : TIMESTAMP
}

' Code Analysis Entities
entity "PullRequest" as pr {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * pr_number : INTEGER
  * github_pr_id : VARCHAR(100)
  * title : VARCHAR(500)
  * author : VARCHAR(100)
  * source_branch : VARCHAR(100)
  * target_branch : VARCHAR(100)
  * status : ENUM(open, closed, merged)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
}

entity "Analysis" as analysis {
  * id : UUID <<PK>>
  * pr_id : UUID <<FK>>
  --
  * status : ENUM(pending, processing, completed, failed)
  * started_at : TIMESTAMP
  * completed_at : TIMESTAMP
  * processing_time : INTEGER
  total_issues : INTEGER
  critical_issues : INTEGER
  high_issues : INTEGER
  medium_issues : INTEGER
  low_issues : INTEGER
}

entity "Issue" as issue {
  * id : UUID <<PK>>
  * analysis_id : UUID <<FK>>
  --
  * file_path : VARCHAR(500)
  * line_number : INTEGER
  * severity : ENUM(critical, high, medium, low)
  * category : VARCHAR(100)
  * title : VARCHAR(200)
  * description : TEXT
  * suggestion : TEXT
  * rule_id : VARCHAR(100)
  * created_at : TIMESTAMP
}

entity "Comment" as comment {
  * id : UUID <<PK>>
  * issue_id : UUID <<FK>>
  --
  * github_comment_id : VARCHAR(100)
  * posted_at : TIMESTAMP
  * status : ENUM(posted, updated, deleted)
}

' Architecture Entities
entity "CodeEntity" as entity {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * entity_type : ENUM(file, class, function, method)
  * name : VARCHAR(200)
  * file_path : VARCHAR(500)
  * line_start : INTEGER
  * line_end : INTEGER
  * complexity : INTEGER
  * created_at : TIMESTAMP
}

entity "Dependency" as dependency {
  * id : UUID <<PK>>
  * source_entity_id : UUID <<FK>>
  * target_entity_id : UUID <<FK>>
  --
  * dependency_type : ENUM(import, call, inheritance, composition)
  * weight : INTEGER
  * created_at : TIMESTAMP
}

' Quality Metrics Entities
entity "QualityMetric" as metric {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * metric_date : DATE
  * total_lines : INTEGER
  * code_coverage : DECIMAL(5,2)
  * avg_complexity : DECIMAL(5,2)
  * technical_debt : INTEGER
  * maintainability_index : DECIMAL(5,2)
  * created_at : TIMESTAMP
}

entity "ComplianceCheck" as compliance {
  * id : UUID <<PK>>
  * analysis_id : UUID <<FK>>
  --
  * standard : VARCHAR(50)
  * clause : VARCHAR(100)
  * status : ENUM(pass, fail, warning)
  * details : TEXT
  * created_at : TIMESTAMP
}

' Configuration Entities
entity "AnalysisConfig" as config {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * enabled_rules : JSON
  * severity_thresholds : JSON
  * compliance_standards : JSON
  * llm_model : VARCHAR(50)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
}

entity "TaskQueue" as queue {
  * id : UUID <<PK>>
  --
  * task_type : VARCHAR(50)
  * payload : JSON
  * status : ENUM(pending, processing, completed, failed)
  * priority : INTEGER
  * created_at : TIMESTAMP
  * started_at : TIMESTAMP
  * completed_at : TIMESTAMP
  retry_count : INTEGER
  error_message : TEXT
}

' Relationships
user ||--o{ session : "has"
user ||--o{ project : "owns"
user ||--o{ member : "participates"

project ||--o{ member : "has"
project ||--o{ pr : "contains"
project ||--o{ entity : "contains"
project ||--o{ metric : "tracks"
project ||--|| config : "configured by"

pr ||--o{ analysis : "analyzed by"

analysis ||--o{ issue : "identifies"
analysis ||--o{ compliance : "checks"

issue ||--o| comment : "posted as"

entity ||--o{ dependency : "depends on (source)"
entity ||--o{ dependency : "depended by (target)"

@enduml
