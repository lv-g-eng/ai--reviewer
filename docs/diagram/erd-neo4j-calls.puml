@startuml Neo4j Graph - Function Calls
!theme plain
skinparam backgroundColor #FFFFFF

title Neo4j Graph Database - CALLS Relationships

' Node definitions
class Function <<Node>> {
  + id : UUID
  + name : String
  + file_path : String
  + complexity : Integer
}

class Method <<Node>> {
  + id : UUID
  + name : String
  + class_name : String
  + is_static : Boolean
}

' Call relationships
Function "caller" --> "callee" Function : CALLS
Function "caller" --> "callee" Method : CALLS
Method "caller" --> "callee" Method : CALLS
Method "caller" --> "callee" Function : CALLS

' Relationship properties
class "CALLS" <<Relationship>> {
  + call_count : Integer
  + is_recursive : Boolean
  + call_sites : List<Integer>
  + created_at : DateTime
  --
  Properties:
  - call_count: Number of times called
  - is_recursive: Self-referential call
  - call_sites: Line numbers where called
}

note right of Function
  Function Call Tracking
  - Direct function calls
  - Callback invocations
  - Event handlers
  
  Example:
  process_data() CALLS validate_input()
  (call_count: 5, call_sites: [45, 67, 89])
end note

note right of Method
  Method Call Tracking
  - Instance method calls
  - Static method calls
  - Constructor calls
  
  Example:
  UserService.create() CALLS UserRepository.save()
  (call_count: 12, is_recursive: false)
end note

note bottom
  Call Graph Analysis Queries:
  
  1. Find Recursive Functions:
     MATCH (f:Function)-[c:CALLS]->(f)
     WHERE c.is_recursive = true
     RETURN f.name, c.call_count
  
  2. Find Most Called Functions:
     MATCH ()-[c:CALLS]->(f:Function)
     WITH f, sum(c.call_count) as total_calls
     RETURN f.name, total_calls
     ORDER BY total_calls DESC
     LIMIT 10
  
  3. Find Call Chains:
     MATCH path = (f1:Function)-[:CALLS*1..5]->(f2:Function)
     WHERE f1.name = 'main'
     RETURN path
  
  4. Find Unused Functions:
     MATCH (f:Function)
     WHERE NOT ()-[:CALLS]->(f)
     RETURN f.name, f.file_path
end note

@enduml
