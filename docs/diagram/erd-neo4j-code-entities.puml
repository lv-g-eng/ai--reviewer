@startuml Neo4j Graph - Code Entities
!theme plain
skinparam backgroundColor #FFFFFF

title Neo4j Graph Database - Code Entity Nodes

' Node definitions
class Module <<Node>> {
  + id : UUID
  + project_id : UUID
  + name : String
  + path : String
  + language : String
  + lines_of_code : Integer
  + complexity : Integer
  + created_at : DateTime
  + updated_at : DateTime
  --
  Constraints:
  - UNIQUE(id)
  - INDEX(project_id)
  - INDEX(name)
}

class Class <<Node>> {
  + id : UUID
  + module_id : UUID
  + name : String
  + file_path : String
  + line_start : Integer
  + line_end : Integer
  + complexity : Integer
  + methods_count : Integer
  + is_abstract : Boolean
  + created_at : DateTime
  --
  Constraints:
  - UNIQUE(id)
  - INDEX(module_id)
  - INDEX(name)
}

class Function <<Node>> {
  + id : UUID
  + parent_id : UUID
  + name : String
  + file_path : String
  + line_start : Integer
  + line_end : Integer
  + complexity : Integer
  + parameters_count : Integer
  + is_async : Boolean
  + is_generator : Boolean
  + created_at : DateTime
  --
  Constraints:
  - UNIQUE(id)
  - INDEX(parent_id)
  - INDEX(name)
}

' Containment relationships
Module "1" *-- "0..*" Class : CONTAINS
Module "1" *-- "0..*" Function : CONTAINS
Class "1" *-- "0..*" Function : CONTAINS

note right of Module
  Represents code modules/packages
  - Python: .py files, packages
  - JavaScript: .js/.ts files, modules
  - Java: packages
  - Go: packages
  
  Examples:
  - src/services/auth.py
  - src/utils/validators.js
  - com.example.services
end note

note right of Class
  Represents class definitions
  - Object-oriented classes
  - Abstract classes
  - Interfaces (TypeScript, Java)
  
  Metrics:
  - Complexity: Cyclomatic complexity
  - Methods count: Number of methods
  - Abstract: Interface or abstract class
end note

note right of Function
  Represents functions/methods
  - Module-level functions
  - Class methods
  - Static methods
  - Async functions
  - Generator functions
  
  Metrics:
  - Complexity: Cyclomatic complexity
  - Parameters: Argument count
  - Async: Asynchronous function
end note

@enduml
