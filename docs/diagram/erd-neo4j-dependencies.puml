@startuml Neo4j Graph - Dependencies
!theme plain
skinparam backgroundColor #FFFFFF

title Neo4j Graph Database - Dependency Relationships

' Node definitions (simplified)
class Module <<Node>> {
  + id : UUID
  + name : String
  + path : String
}

class Class <<Node>> {
  + id : UUID
  + name : String
}

class Function <<Node>> {
  + id : UUID
  + name : String
}

' Dependency relationships
Module "source" --> "target" Module : DEPENDS_ON
Class "source" --> "target" Class : DEPENDS_ON
Function "source" --> "target" Function : DEPENDS_ON

' Relationship properties
class "DEPENDS_ON" <<Relationship>> {
  + type : String
  + strength : Integer
  + created_at : DateTime
  + last_updated : DateTime
  --
  Types:
  - import: Module imports
  - call: Function calls
  - inheritance: Class inheritance
  - composition: Class composition
  - aggregation: Class aggregation
  --
  Strength: 1-10
  - Based on usage frequency
  - Higher = stronger coupling
}

note right of Module
  Module Dependencies
  - Import statements
  - Package dependencies
  - External libraries
  
  Example:
  auth.py DEPENDS_ON database.py
  (type: import, strength: 5)
end note

note right of Class
  Class Dependencies
  - Inheritance relationships
  - Composition relationships
  - Association relationships
  
  Example:
  UserService DEPENDS_ON UserRepository
  (type: composition, strength: 8)
end note

note right of Function
  Function Dependencies
  - Function calls
  - Method invocations
  - Callback references
  
  Example:
  validate_user() DEPENDS_ON check_password()
  (type: call, strength: 3)
end note

note bottom
  Dependency Analysis Queries:
  
  1. Find Circular Dependencies:
     MATCH path = (m:Module)-[:DEPENDS_ON*2..10]->(m)
     RETURN path
  
  2. Calculate Coupling:
     MATCH (m:Module)
     OPTIONAL MATCH (m)-[r:DEPENDS_ON]->()
     RETURN m.name, count(r) as coupling
  
  3. Find Highly Coupled Modules:
     MATCH (m:Module)-[r:DEPENDS_ON]->()
     WITH m, count(r) as deps
     WHERE deps > 5
     RETURN m.name, deps
     ORDER BY deps DESC
end note

@enduml
