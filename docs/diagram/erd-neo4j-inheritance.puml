@startuml Neo4j Graph - Inheritance
!theme plain
skinparam backgroundColor #FFFFFF

title Neo4j Graph Database - INHERITS Relationships

' Node definitions
class Class <<Node>> {
  + id : UUID
  + name : String
  + is_abstract : Boolean
  + is_interface : Boolean
}

class Interface <<Node>> {
  + id : UUID
  + name : String
  + methods : List<String>
}

' Inheritance relationships
Class "child" --|> "parent" Class : INHERITS
Class "implementer" ..|> "interface" Interface : IMPLEMENTS
Interface "child" --|> "parent" Interface : EXTENDS

' Relationship properties
class "INHERITS" <<Relationship>> {
  + inheritance_type : String
  + created_at : DateTime
  --
  Types:
  - single: Single inheritance
  - multiple: Multiple inheritance (Python, C++)
  - interface: Interface implementation
}

class "IMPLEMENTS" <<Relationship>> {
  + created_at : DateTime
  --
  Interface implementation
  - Java, TypeScript, Go
}

class "EXTENDS" <<Relationship>> {
  + created_at : DateTime
  --
  Interface extension
  - TypeScript, Java
}

note right of Class
  Class Inheritance
  - Single inheritance (Java, C#)
  - Multiple inheritance (Python, C++)
  - Abstract classes
  
  Example:
  UserService INHERITS BaseService
  (inheritance_type: single)
  
  AdminService INHERITS UserService
  (inheritance_type: single)
end note

note right of Interface
  Interface Relationships
  - Interface implementation
  - Interface extension
  - Multiple interfaces
  
  Example:
  UserRepository IMPLEMENTS IRepository
  UserRepository IMPLEMENTS ILoggable
end note

note bottom
  Inheritance Analysis Queries:
  
  1. Find Inheritance Hierarchy:
     MATCH path = (c:Class)-[:INHERITS*]->(base:Class)
     WHERE c.name = 'AdminService'
     RETURN path
  
  2. Find Depth of Inheritance:
     MATCH path = (c:Class)-[:INHERITS*]->(base:Class)
     WITH c, length(path) as depth
     WHERE depth > 3
     RETURN c.name, depth
     ORDER BY depth DESC
  
  3. Find Classes with Multiple Inheritance:
     MATCH (c:Class)-[:INHERITS]->(parent:Class)
     WITH c, count(parent) as parent_count
     WHERE parent_count > 1
     RETURN c.name, parent_count
  
  4. Find All Implementations of Interface:
     MATCH (c:Class)-[:IMPLEMENTS]->(i:Interface)
     WHERE i.name = 'IRepository'
     RETURN c.name
  
  5. Find Abstract Classes:
     MATCH (c:Class)
     WHERE c.is_abstract = true
     RETURN c.name
end note

@enduml
