@startuml PostgreSQL ERD - Code Analysis
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

title PostgreSQL Entity Relationship Diagram - Code Analysis Module

' Reference to Project (from Project Management module)
entity "Project" as project {
  * id : UUID <<PK>>
  --
  * name : VARCHAR(200)
  ...
}

entity "PullRequest" as pr {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * pr_number : INTEGER
  * github_pr_id : VARCHAR(100)
  * title : VARCHAR(500)
  * author : VARCHAR(100)
  * source_branch : VARCHAR(100)
  * target_branch : VARCHAR(100)
  * status : ENUM(open, closed, merged)
  * created_at : TIMESTAMP
  * updated_at : TIMESTAMP
  closed_at : TIMESTAMP
}

entity "Analysis" as analysis {
  * id : UUID <<PK>>
  * pr_id : UUID <<FK>>
  --
  * status : ENUM(pending, processing, completed, failed)
  * started_at : TIMESTAMP
  completed_at : TIMESTAMP
  processing_time : INTEGER
  total_issues : INTEGER
  critical_issues : INTEGER
  high_issues : INTEGER
  medium_issues : INTEGER
  low_issues : INTEGER
  quality_score : DECIMAL(5,2)
  error_message : TEXT
}

entity "Issue" as issue {
  * id : UUID <<PK>>
  * analysis_id : UUID <<FK>>
  --
  * severity : ENUM(critical, high, medium, low)
  * category : VARCHAR(100)
  * title : VARCHAR(200)
  * description : TEXT
  suggestion : TEXT
  * file_path : VARCHAR(500)
  * line_number : INTEGER
  code_snippet : TEXT
  rule_id : VARCHAR(100)
  * created_at : TIMESTAMP
  user_feedback : ENUM(accept, dismiss, false_positive)
  feedback_comment : TEXT
  feedback_at : TIMESTAMP
}

entity "Comment" as comment {
  * id : UUID <<PK>>
  * issue_id : UUID <<FK>>
  --
  * github_comment_id : VARCHAR(100)
  * posted_at : TIMESTAMP
  * status : ENUM(posted, updated, deleted)
}

entity "ComplianceCheck" as compliance {
  * id : UUID <<PK>>
  * analysis_id : UUID <<FK>>
  --
  * standard : VARCHAR(50)
  * clause : VARCHAR(100)
  * status : ENUM(pass, fail, warning)
  details : TEXT
  * created_at : TIMESTAMP
}

' Relationships
project ||--o{ pr : "contains"
pr ||--o{ analysis : "analyzed by"
analysis ||--o{ issue : "identifies"
analysis ||--o{ compliance : "checks"
issue ||--o| comment : "posted as"

note right of pr
  Pull request tracking
  - GitHub PR integration
  - Status tracking
  - Author information
  - Branch details
end note

note right of analysis
  Analysis execution
  - Processing status
  - Performance metrics
  - Issue statistics
  - Quality score (0-100)
  - Error handling
end note

note right of issue
  Detected code issues
  - Severity classification
  - Category (security, performance, style)
  - File location
  - User feedback support
  - Actionable suggestions
end note

note right of compliance
  Standards compliance
  - ISO/IEC 25010
  - ISO/IEC 23396
  - Google Style Guides
  - Pass/Fail/Warning status
end note

@enduml
