@startuml PostgreSQL ERD - Quality Metrics
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

title PostgreSQL Entity Relationship Diagram - Quality Metrics Module

' Reference to Project (from Project Management module)
entity "Project" as project {
  * id : UUID <<PK>>
  --
  * name : VARCHAR(200)
  ...
}

entity "QualityMetric" as metric {
  * id : UUID <<PK>>
  * project_id : UUID <<FK>>
  --
  * metric_date : DATE
  total_lines : INTEGER
  code_coverage : DECIMAL(5,2)
  avg_complexity : DECIMAL(5,2)
  technical_debt : INTEGER
  maintainability_index : DECIMAL(5,2)
  * created_at : TIMESTAMP
}

entity "TaskQueue" as queue {
  * id : UUID <<PK>>
  --
  * task_type : VARCHAR(50)
  * payload : JSON
  * status : ENUM(pending, processing, completed, failed)
  * priority : INTEGER
  * created_at : TIMESTAMP
  started_at : TIMESTAMP
  completed_at : TIMESTAMP
  retry_count : INTEGER
  error_message : TEXT
}

' Relationships
project ||--o{ metric : "tracks"

note right of metric
  Quality metrics tracking
  - Daily snapshots
  - Code coverage percentage
  - Cyclomatic complexity
  - Technical debt (hours)
  - Maintainability index (0-100)
  - Trend analysis support
end note

note right of queue
  Asynchronous task management
  - Task type: analysis, sync, report
  - Priority-based processing
  - Retry mechanism (max 3)
  - Error tracking
  - Performance monitoring
end note

note bottom of project
  Quality Metrics Features:
  - Historical tracking
  - Trend visualization
  - Comparison over time
  - Exportable reports
  - Dashboard integration
end note

@enduml
