@startuml Security Architecture
!theme plain
skinparam backgroundColor #FFFFFF

title AI-Based Code Reviewer - Security Architecture (Defense in Depth)

package "Layer 1: Network Security" #LightBlue {
  component "Firewall Rules" as firewall {
    [Inbound Rules]
    [Outbound Rules]
    [IP Whitelisting]
  }
  
  component "DDoS Protection" as ddos {
    [CloudFlare Shield]
    [AWS Shield]
    [Rate Limiting]
  }
  
  component "VPC Isolation" as vpc {
    [Private Subnets]
    [Security Groups]
    [Network ACLs]
  }
  
  component "WAF" as waf {
    [SQL Injection Rules]
    [XSS Protection]
    [Bot Detection]
  }
}

package "Layer 2: Transport Security" #LightGreen {
  component "TLS 1.3" as tls {
    [Certificate Management]
    [Let's Encrypt]
    [Auto-renewal]
  }
  
  component "HTTPS Enforcement" as https {
    [HSTS Headers]
    [Redirect HTTP→HTTPS]
    [Secure Cookies]
  }
  
  component "Certificate Pinning" as pinning {
    [Public Key Pinning]
    [Certificate Validation]
  }
}

package "Layer 3: Application Security" #LightYellow {
  
  package "Authentication" {
    component "JWT Manager" as jwt {
      [Token Generation]
      [Token Validation]
      [Token Refresh]
      [Token Revocation]
    }
    
    component "Password Security" as password {
      [bcrypt Hashing]
      [Cost Factor: 12]
      [Password Policy]
      [History Check]
    }
    
    component "OAuth 2.0" as oauth {
      [GitHub Integration]
      [Authorization Code Flow]
      [Token Storage]
    }
    
    component "Account Protection" as account {
      [Failed Login Tracking]
      [Account Lockout]
      [CAPTCHA]
      [2FA (Future)]
    }
  }
  
  package "Authorization" {
    component "RBAC Engine" as rbac {
      [Role Hierarchy]
      [Permission Matrix]
      [Resource-level ACL]
    }
    
    component "Permission Checker" as permission {
      [API Endpoint Guards]
      [Decorator-based]
      [Context-aware]
    }
  }
  
  package "Input Validation" {
    component "Request Validator" as validator {
      [Pydantic Schemas]
      [Type Checking]
      [Format Validation]
    }
    
    component "Sanitizer" as sanitizer {
      [HTML Escaping]
      [SQL Injection Prevention]
      [XSS Prevention]
      [Path Traversal Prevention]
    }
    
    component "CSRF Protection" as csrf {
      [Token Generation]
      [Token Validation]
      [SameSite Cookies]
    }
  }
  
  package "API Security" {
    component "Rate Limiter" as rate_limit {
      [Per-User Limits]
      [Per-IP Limits]
      [Sliding Window]
    }
    
    component "CORS Policy" as cors {
      [Allowed Origins]
      [Allowed Methods]
      [Credentials Handling]
    }
    
    component "API Key Management" as api_keys {
      [Key Generation]
      [Key Rotation]
      [Key Revocation]
    }
  }
}

package "Layer 4: Data Security" #LightCoral {
  
  package "Encryption at Rest" {
    component "Database Encryption" as db_encrypt {
      [PostgreSQL TDE]
      [Neo4j Encrypted Volumes]
      [Redis Encrypted Snapshots]
    }
    
    component "Field-level Encryption" as field_encrypt {
      [AES-256]
      [Sensitive Data]
      [GitHub Tokens]
      [Webhook Secrets]
    }
    
    component "Backup Encryption" as backup_encrypt {
      [S3 Server-side Encryption]
      [Encrypted Snapshots]
    }
  }
  
  package "Encryption in Transit" {
    component "Internal TLS" as internal_tls {
      [Service-to-Service]
      [mTLS (Future)]
    }
    
    component "Database Connections" as db_tls {
      [PostgreSQL SSL]
      [Neo4j Bolt+TLS]
      [Redis TLS]
    }
  }
  
  package "Key Management" {
    component "AWS KMS" as kms {
      [Master Keys]
      [Key Rotation]
      [Key Policies]
    }
    
    component "Secrets Manager" as secrets {
      [API Keys]
      [DB Credentials]
      [Encryption Keys]
      [Auto-rotation]
    }
    
    component "Environment Variables" as env {
      [Encrypted at Rest]
      [Access Control]
      [Audit Logging]
    }
  }
  
  package "Data Access Control" {
    component "Database ACL" as db_acl {
      [User Permissions]
      [Row-level Security]
      [Column Masking]
    }
    
    component "Data Classification" as classification {
      [Public]
      [Internal]
      [Confidential]
      [Restricted]
    }
  }
}

package "Layer 5: Monitoring & Audit" #LightPink {
  component "Audit Logging" as audit {
    [Authentication Events]
    [Authorization Failures]
    [Data Access]
    [Configuration Changes]
    [7-year Retention]
  }
  
  component "Security Monitoring" as monitoring {
    [Intrusion Detection]
    [Anomaly Detection]
    [Failed Login Alerts]
    [Suspicious Activity]
  }
  
  component "Compliance Reporting" as compliance {
    [GDPR Reports]
    [SOC 2 Evidence]
    [Access Reports]
    [Incident Reports]
  }
  
  component "Vulnerability Scanning" as vuln_scan {
    [Dependency Scanning]
    [Container Scanning]
    [Code Scanning]
    [Weekly Scans]
  }
}

package "Layer 6: Incident Response" #LightSalmon {
  component "Alerting" as alerting {
    [PagerDuty]
    [Slack Notifications]
    [Email Alerts]
  }
  
  component "Incident Management" as incident {
    [Runbooks]
    [Escalation Procedures]
    [Post-mortem Process]
  }
  
  component "Backup & Recovery" as recovery {
    [Automated Backups]
    [Point-in-time Recovery]
    [Disaster Recovery Plan]
  }
}

' Security Flow
actor "User" as user
actor "Attacker" as attacker #Red

user --> firewall : Legitimate Request
attacker -[#Red]-> firewall : Attack Attempt
firewall --> ddos : Filter
ddos --> waf : Inspect
waf --> tls : Decrypt
tls --> jwt : Validate Token
jwt --> rbac : Check Permissions
rbac --> validator : Validate Input
validator --> sanitizer : Sanitize
sanitizer --> db_encrypt : Access Data
db_encrypt --> audit : Log Access

attacker -[#Red]x firewall : Blocked
attacker -[#Red]x ddos : Rate Limited
attacker -[#Red]x waf : Filtered
attacker -[#Red]x jwt : Invalid Token
attacker -[#Red]x rbac : Unauthorized
attacker -[#Red]x validator : Invalid Input

' Monitoring Flow
audit --> monitoring : Events
monitoring --> alerting : Alerts
alerting --> incident : Trigger

' Key Management Flow
secrets --> jwt : Signing Key
secrets --> field_encrypt : Encryption Key
kms --> secrets : Master Key
kms --> db_encrypt : DEK

note right of firewall
  First line of defense
  - Block malicious IPs
  - Limit connection rates
  - Geographic restrictions
end note

note right of jwt
  Token Security:
  - HS256 algorithm
  - 24-hour expiry
  - Refresh tokens: 7 days
  - Revocation list in Redis
end note

note right of rbac
  Permission Matrix:
  - 6 roles (Guest to Admin)
  - Resource-level permissions
  - Hierarchical inheritance
  - Audit all access
end note

note right of db_encrypt
  Encryption Standards:
  - AES-256-GCM
  - TLS 1.3
  - Key rotation: 90 days
  - FIPS 140-2 compliant
end note

note right of audit
  Audit Requirements:
  - All auth events
  - All data access
  - All config changes
  - Immutable logs
  - 7-year retention
end note

@enduml
