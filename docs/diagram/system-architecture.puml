@startuml System Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

title AI-Based Code Reviewer - System Architecture

' External Actors
actor "Developer" as dev #LightBlue
actor "Reviewer" as reviewer #LightGreen
actor "Manager" as manager #LightYellow

' External Systems
cloud "GitHub" as github #LightGray {
  component "GitHub API" as github_api
  component "Webhooks" as webhooks
}

cloud "LLM Services" as llm #LightGray {
  component "OpenAI GPT-4" as gpt4
  component "Anthropic Claude" as claude
}

' Client Layer
package "Client Layer" {
  component "Web Browser\n(React/Next.js)" as browser
  component "Mobile App" as mobile
}

' API Gateway
package "API Gateway Layer" {
  component "Kong/Nginx\nAPI Gateway" as gateway {
    [Rate Limiting]
    [Authentication]
    [Load Balancing]
    [SSL Termination]
  }
}

' Application Services
package "Application Layer" {
  component "Auth Service\n(FastAPI)" as auth
  component "Project Manager\n(FastAPI)" as project_mgr
  component "Analysis Service\n(FastAPI)" as analysis_svc
  component "Webhook Handler\n(FastAPI)" as webhook
  component "Metrics Service\n(FastAPI)" as metrics
}

' Worker Services
package "Worker Layer" {
  component "Code Review Engine\n(Celery)" as review_engine
  component "Architecture Analyzer\n(Celery)" as arch_analyzer
  component "Agentic AI Service\n(Celery)" as ai_service
}

' Data Layer
package "Data Layer" {
  database "PostgreSQL\n(RDS)" as postgres {
    [Users]
    [Projects]
    [Analyses]
    [Issues]
    [Audit Logs]
  }
  
  database "Neo4j\n(EC2)" as neo4j {
    [Modules]
    [Classes]
    [Functions]
    [Dependencies]
  }
  
  database "Redis\n(ElastiCache)" as redis {
    [Task Queue]
    [Cache]
    [Sessions]
  }
}

' Monitoring & Logging
package "Observability" {
  component "Prometheus" as prometheus
  component "Grafana" as grafana
  component "ELK Stack" as elk
}

' Relationships - Client to Gateway
dev --> browser
reviewer --> browser
manager --> browser
browser --> gateway : HTTPS
mobile --> gateway : HTTPS

' Gateway to Services
gateway --> auth : /api/auth/*
gateway --> project_mgr : /api/repositories/*
gateway --> analysis_svc : /api/analyses/*
gateway --> webhook : /api/webhooks/*
gateway --> metrics : /api/metrics/*

' Services to Data
auth --> postgres : User data
auth --> redis : Sessions
project_mgr --> postgres : Projects
project_mgr --> github_api : OAuth, Repo info
analysis_svc --> postgres : Analysis results
analysis_svc --> redis : Queue tasks
webhook --> redis : Queue tasks
metrics --> postgres : Metrics
metrics --> neo4j : Graph metrics

' Workers to Data
review_engine --> postgres : Store results
review_engine --> neo4j : Update graph
review_engine --> redis : Dequeue tasks
review_engine --> github_api : Fetch code, Post comments
review_engine --> ai_service : Request analysis

arch_analyzer --> neo4j : Query/Update graph
arch_analyzer --> postgres : Store violations

ai_service --> gpt4 : Analysis request
ai_service --> claude : Fallback request

' Monitoring
auth ..> prometheus : Metrics
project_mgr ..> prometheus : Metrics
analysis_svc ..> prometheus : Metrics
review_engine ..> prometheus : Metrics
prometheus --> grafana : Visualize
auth ..> elk : Logs
project_mgr ..> elk : Logs
analysis_svc ..> elk : Logs

' External to Internal
github --> webhook : PR events

note right of gateway
  - TLS 1.3 encryption
  - Rate limiting: 100 req/min
  - JWT validation
  - CORS policy
end note

note right of redis
  - Task queue (Celery)
  - Session cache (TTL: 24h)
  - API response cache
end note

note right of postgres
  - Primary: us-east-1
  - Replica: eu-west-1
  - Automated backups
  - Encryption at rest
end note

@enduml
