@startuml Use Case Diagram
!theme plain
skinparam backgroundColor #FFFFFF

title AI-Based Code Reviewer - Use Case Diagram

left to right direction

' Actors
actor "Guest" as guest #LightGray
actor "User" as user #LightBlue
actor "Programmer" as programmer #LightGreen
actor "Reviewer" as reviewer #LightYellow
actor "Manager" as manager #LightCoral
actor "Administrator" as admin #LightPink

' External Systems
actor "GitHub" as github #LightGray
actor "LLM API" as llm #LightGray

' Inheritance
user <|-- programmer
programmer <|-- reviewer
reviewer <|-- manager
user <|-- admin

rectangle "AI-Based Code Reviewer Platform" {
  
  ' Authentication & User Management
  package "Authentication" {
    usecase "UC-01: Register Account" as UC01
    usecase "UC-02: Login" as UC02
    usecase "Logout" as logout
    usecase "Reset Password" as reset_pwd
    usecase "Verify Email" as verify_email
  }
  
  ' Repository Management
  package "Repository Management" {
    usecase "UC-03: Add Repository" as UC03
    usecase "Configure Webhook" as config_webhook
    usecase "Sync Repository" as sync_repo
    usecase "Remove Repository" as remove_repo
    usecase "View Repository List" as view_repos
  }
  
  ' Code Analysis
  package "Code Analysis" {
    usecase "UC-04: Automated PR Review" as UC04
    usecase "Parse Source Code" as parse_code
    usecase "Analyze with LLM" as analyze_llm
    usecase "Detect Issues" as detect_issues
    usecase "Post Review Comments" as post_comments
    usecase "Provide Feedback on Issues" as feedback
  }
  
  ' Architecture Analysis
  package "Architecture Analysis" {
    usecase "UC-05: View Dependency Graph" as UC05
    usecase "Detect Circular Dependencies" as detect_cycles
    usecase "Identify Layer Violations" as layer_violations
    usecase "Calculate Coupling Metrics" as coupling
    usecase "Export Graph" as export_graph
  }
  
  ' Quality Metrics
  package "Quality Metrics" {
    usecase "UC-06: View Quality Dashboard" as UC06
    usecase "Generate Reports" as generate_reports
    usecase "Export Metrics" as export_metrics
    usecase "View Trends" as view_trends
  }
  
  ' System Configuration
  package "System Configuration" {
    usecase "UC-07: Configure Settings" as UC07
    usecase "Manage Users" as manage_users
    usecase "Set Compliance Standards" as compliance
    usecase "View Audit Logs" as audit_logs
    usecase "Configure Integrations" as integrations
  }
}

' Guest relationships
guest --> UC01
guest --> UC02

' User relationships
user --> logout
user --> reset_pwd
user --> verify_email
user --> UC03
user --> view_repos
user --> sync_repo

' Programmer relationships
programmer --> feedback
programmer --> UC05
programmer --> export_graph

' Reviewer relationships
reviewer --> UC06
reviewer --> view_trends

' Manager relationships
manager --> generate_reports
manager --> export_metrics

' Administrator relationships
admin --> UC07
admin --> manage_users
admin --> compliance
admin --> audit_logs
admin --> integrations
admin --> remove_repo

' System relationships
UC03 ..> config_webhook : <<include>>
UC04 ..> parse_code : <<include>>
UC04 ..> analyze_llm : <<include>>
UC04 ..> detect_issues : <<include>>
UC04 ..> post_comments : <<include>>
UC05 ..> detect_cycles : <<include>>
UC05 ..> layer_violations : <<include>>
UC05 ..> coupling : <<include>>

' External system relationships
github --> UC04 : triggers
UC04 --> github : posts comments
config_webhook --> github : configures
analyze_llm --> llm : requests analysis

' Notes
note right of UC04
  Triggered automatically
  when PR is created or
  updated on GitHub
end note

note right of UC05
  Interactive visualization
  with zoom, pan, and
  filter capabilities
end note

note right of UC07
  Admin-only access
  All changes audited
end note

@enduml
