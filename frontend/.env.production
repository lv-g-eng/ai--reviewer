# ============================================================================
# Frontend Production Environment Configuration
# ============================================================================
# Deploy to production environment via CI/CD
# ALL sensitive values MUST be stored in AWS Secrets Manager
# ============================================================================

# API Configuration
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.example.com/ws

# Application Configuration
NEXT_PUBLIC_APP_NAME="AI Code Review Platform"
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=production

# Authentication Configuration
NEXTAUTH_URL=https://app.example.com
NEXTAUTH_SECRET=${AWS_SECRET:production/frontend/nextauth_secret}
NEXT_PUBLIC_SESSION_TIMEOUT=86400

# Feature Flags
NEXT_PUBLIC_ENABLE_GITHUB_INTEGRATION=true
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false

# GitHub OAuth
GITHUB_CLIENT_ID=${AWS_SECRET:production/oauth/github_client_id}
GITHUB_CLIENT_SECRET=${AWS_SECRET:production/oauth/github_client_secret}
GITHUB_CALLBACK_URL=https://app.example.com/api/auth/callback/github

# Google OAuth
GOOGLE_CLIENT_ID=${AWS_SECRET:production/oauth/google_client_id}
GOOGLE_CLIENT_SECRET=${AWS_SECRET:production/oauth/google_client_secret}
GOOGLE_CALLBACK_URL=https://app.example.com/api/auth/callback/google

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=${AWS_SECRET:production/monitoring/ga_tracking_id}
NEXT_PUBLIC_SENTRY_DSN=${AWS_SECRET:production/monitoring/sentry_dsn}

# Performance Configuration
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_MAX_RETRIES=3
NEXT_PUBLIC_RETRY_DELAY=1000

# UI Configuration
NEXT_PUBLIC_DEFAULT_THEME=light
NEXT_PUBLIC_ITEMS_PER_PAGE=20
NEXT_PUBLIC_MAX_FILE_SIZE=10485760

# Graph Visualization Configuration
NEXT_PUBLIC_GRAPH_MAX_NODES=1000
NEXT_PUBLIC_GRAPH_PHYSICS_ENABLED=true
NEXT_PUBLIC_GRAPH_ZOOM_MIN=0.1
NEXT_PUBLIC_GRAPH_ZOOM_MAX=10

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=5

# Development Configuration
NEXT_PUBLIC_MOCK_API=false
NEXT_PUBLIC_LOG_LEVEL=error
