# ============================================
# API Gateway Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# DO NOT commit .env file to version control
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------

# Port number for the API Gateway server
# Default: 3000
PORT=3000

# Node environment (development, staging, production)
# Affects logging, error handling, and performance optimizations
# Default: development
NODE_ENV=development

# --------------------------------------------
# Microservice URLs
# --------------------------------------------
# URLs for backend microservices
# Update these based on your deployment environment

# Authentication Service
# Handles user authentication, authorization, and admin operations
# Default: http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3001

# Code Review Engine Service
# Performs AI-powered code reviews and analysis
# Default: http://localhost:3002
CODE_REVIEW_ENGINE_URL=http://localhost:3002

# Architecture Analyzer Service
# Analyzes project architecture and dependencies
# Default: http://localhost:3003
ARCHITECTURE_ANALYZER_URL=http://localhost:3003

# Agentic AI Service
# Manages AI agents and task queue
# Default: http://localhost:3004
AGENTIC_AI_URL=http://localhost:3004

# Project Manager Service
# Manages projects, repositories, and settings
# Default: http://localhost:3005
PROJECT_MANAGER_URL=http://localhost:3005

# --------------------------------------------
# JWT Configuration
# --------------------------------------------

# JWT Secret Key (REQUIRED)
# IMPORTANT: Change this to a strong, random secret in production
# Generate with: openssl rand -base64 32
# NEVER commit the actual secret to version control
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token Expiration Time
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days)
# Examples: 30m, 1h, 24h, 7d
# Default: 24h
JWT_EXPIRES_IN=24h

# --------------------------------------------
# Redis Configuration
# --------------------------------------------

# Redis Connection URL (REQUIRED for rate limiting)
# Format: redis://[username:password@]host:port[/database]
# Examples:
#   - Local: redis://localhost:6379
#   - With auth: redis://:password@localhost:6379
#   - Remote: redis://user:pass@redis.example.com:6379/0
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Redis Connection Options (Optional)
# Uncomment and configure if needed

# Maximum number of retry attempts
# REDIS_MAX_RETRIES=3

# Retry delay in milliseconds
# REDIS_RETRY_DELAY=1000

# Connection timeout in milliseconds
# REDIS_CONNECT_TIMEOUT=10000

# --------------------------------------------
# CORS Configuration
# --------------------------------------------

# Allowed Origins for CORS (comma-separated)
# List of domains allowed to make requests to the API
# Use * for development only (NOT recommended for production)
# Examples:
#   - Single origin: http://localhost:3000
#   - Multiple origins: http://localhost:3000,https://app.example.com
# Default: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --------------------------------------------
# Rate Limiting Configuration
# --------------------------------------------

# Rate Limit Window (in milliseconds)
# Time window for rate limiting
# Examples:
#   - 1 minute: 60000
#   - 15 minutes: 900000
#   - 1 hour: 3600000
# Default: 900000 (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum Requests per Window
# Maximum number of requests allowed per IP within the time window
# Adjust based on your API usage patterns
# Default: 100
RATE_LIMIT_MAX=100

# Auth Rate Limit Window (in milliseconds)
# Stricter rate limit for authentication endpoints
# Default: 900000 (15 minutes)
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Auth Maximum Requests per Window
# Lower limit for authentication to prevent brute force attacks
# Default: 5
AUTH_RATE_LIMIT_MAX=5

# --------------------------------------------
# Logging Configuration
# --------------------------------------------

# Log Level
# Controls verbosity of logs
# Options: error, warn, info, http, verbose, debug, silly
# Recommended:
#   - Production: warn or error
#   - Staging: info
#   - Development: debug
# Default: info
LOG_LEVEL=info

# Log Format
# Format for log output
# Options: json, simple, combined
# Recommended: json for production (easier to parse)
# Default: json
LOG_FORMAT=json

# Log to File
# Enable/disable file logging
# Options: true, false
# Default: true
LOG_TO_FILE=true

# Log Directory
# Directory for log files (relative to project root)
# Default: logs
LOG_DIR=logs

# --------------------------------------------
# Circuit Breaker Configuration
# --------------------------------------------

# Circuit Breaker Timeout (in milliseconds)
# Maximum time to wait for a service response before timing out
# Default: 10000 (10 seconds)
CIRCUIT_BREAKER_TIMEOUT=10000

# Circuit Breaker Error Threshold Percentage
# Percentage of errors that will trigger the circuit breaker to open
# Range: 0-100
# Default: 50 (50% error rate)
CIRCUIT_BREAKER_ERROR_THRESHOLD=50

# Circuit Breaker Reset Timeout (in milliseconds)
# Time to wait before attempting to close an open circuit
# Default: 60000 (1 minute)
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# Circuit Breaker Volume Threshold
# Minimum number of requests before circuit breaker can open
# Prevents opening on low traffic
# Default: 10
CIRCUIT_BREAKER_VOLUME_THRESHOLD=10

# --------------------------------------------
# GitHub Webhook Configuration
# --------------------------------------------

# GitHub Webhook Secret (Optional)
# Secret used to verify GitHub webhook signatures
# Set this if you're using GitHub webhooks
# Generate in GitHub: Settings > Webhooks > Add webhook
# Default: (empty)
GITHUB_WEBHOOK_SECRET=

# --------------------------------------------
# Request Configuration
# --------------------------------------------

# Maximum Request Body Size
# Limit for JSON request body size
# Format: number + unit (b, kb, mb, gb)
# Default: 10mb
MAX_REQUEST_BODY_SIZE=10mb

# Request Timeout (in milliseconds)
# Maximum time to wait for a request to complete
# Default: 30000 (30 seconds)
REQUEST_TIMEOUT=30000

# --------------------------------------------
# Security Configuration
# --------------------------------------------

# Enable Helmet Security Headers
# Adds various HTTP headers for security
# Options: true, false
# Default: true
ENABLE_HELMET=true

# Enable CORS
# Enable Cross-Origin Resource Sharing
# Options: true, false
# Default: true
ENABLE_CORS=true

# Trust Proxy
# Trust proxy headers (X-Forwarded-For, etc.)
# Set to true if behind a reverse proxy (nginx, load balancer)
# Options: true, false
# Default: false
TRUST_PROXY=false

# --------------------------------------------
# Performance Configuration
# --------------------------------------------

# Enable Response Compression
# Compress HTTP responses (gzip)
# Options: true, false
# Default: true
ENABLE_COMPRESSION=true

# Enable Request Caching
# Cache GET requests (requires Redis)
# Options: true, false
# Default: false
ENABLE_CACHING=false

# Cache TTL (in seconds)
# Time to live for cached responses
# Default: 300 (5 minutes)
CACHE_TTL=300

# --------------------------------------------
# Monitoring Configuration
# --------------------------------------------

# Enable Metrics Collection
# Collect and expose Prometheus metrics
# Options: true, false
# Default: false
ENABLE_METRICS=false

# Metrics Port
# Port for Prometheus metrics endpoint
# Default: 9090
METRICS_PORT=9090

# Enable Health Check
# Enable /health endpoint
# Options: true, false
# Default: true
ENABLE_HEALTH_CHECK=true

# --------------------------------------------
# Development Configuration
# --------------------------------------------

# Enable Debug Mode
# Additional debug logging and error details
# Options: true, false
# Default: false (set to true only in development)
DEBUG_MODE=false

# Enable Hot Reload
# Automatically restart on file changes (development only)
# Options: true, false
# Default: true
ENABLE_HOT_RELOAD=true

# Mock Services
# Use mock services instead of real microservices (testing only)
# Options: true, false
# Default: false
MOCK_SERVICES=false

# --------------------------------------------
# Optional: Database Configuration
# --------------------------------------------
# Uncomment if API Gateway needs direct database access

# Database URL
# DATABASE_URL=postgresql://user:password@localhost:5432/api_gateway

# Database Pool Size
# DATABASE_POOL_SIZE=10

# --------------------------------------------
# Optional: Message Queue Configuration
# --------------------------------------------
# Uncomment if using message queue (RabbitMQ, Kafka, etc.)

# RabbitMQ URL
# RABBITMQ_URL=amqp://localhost:5672

# Kafka Brokers
# KAFKA_BROKERS=localhost:9092

# --------------------------------------------
# Optional: External Services
# --------------------------------------------

# Sentry DSN (Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic License Key (APM)
# NEW_RELIC_LICENSE_KEY=your-license-key

# DataDog API Key (Monitoring)
# DATADOG_API_KEY=your-api-key

# --------------------------------------------
# Notes
# --------------------------------------------
# 
# REQUIRED VARIABLES:
# - PORT
# - NODE_ENV
# - JWT_SECRET
# - REDIS_URL
# - All *_SERVICE_URL variables
#
# OPTIONAL VARIABLES:
# - All other variables have sensible defaults
#
# SECURITY BEST PRACTICES:
# 1. Never commit .env file to version control
# 2. Use strong, random secrets for JWT_SECRET
# 3. Rotate secrets regularly
# 4. Use different secrets for each environment
# 5. Limit CORS_ALLOWED_ORIGINS in production
# 6. Enable rate limiting in production
# 7. Set LOG_LEVEL to 'warn' or 'error' in production
#
# PRODUCTION CHECKLIST:
# [ ] Change JWT_SECRET to a strong random value
# [ ] Update all *_SERVICE_URL to production URLs
# [ ] Set NODE_ENV=production
# [ ] Configure CORS_ALLOWED_ORIGINS with actual domains
# [ ] Set appropriate RATE_LIMIT_MAX for your use case
# [ ] Set LOG_LEVEL=warn or LOG_LEVEL=error
# [ ] Enable TRUST_PROXY if behind reverse proxy
# [ ] Configure monitoring tools (Sentry, New Relic, etc.)
# [ ] Set up Redis with authentication
# [ ] Review and adjust circuit breaker settings
#
# ============================================
