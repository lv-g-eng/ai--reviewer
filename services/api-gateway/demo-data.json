  "demoScenarios": [
    {
      "name": "Happy Path - Complete Workflow",
      "description": "Demonstrates successful request flow through all middleware layers",
      "steps": [
        "Health check to verify system status",
        "Authenticate user with valid JWT token",
        "Create new project with valid data",
        "List projects with pagination",
        "Get project statistics",
        "Create code review for project",
        "Check queue status"
      ],
      "expectedOutcomes": [
        "All requests succeed with 200/201 status codes",
        "Correlation IDs present in all responses",
        "Rate limit headers included",
        "Response times under 100ms for routing"
      ]
    },
    {
      "name": "Authentication & Authorization",
      "description": "Tests JWT authentication and role-based access control",
      "steps": [
        "Attempt access without authentication (should fail)",
        "Access with invalid JWT token (should fail)",
        "User accessing user endpoints (should succeed)",
        "User accessing admin endpoints (should fail)",
        "Admin accessing admin endpoints (should succeed)"
      ],
      "expectedOutcomes": [
        "Proper 401 Unauthorized responses",
        "Proper 403 Forbidden responses",
        "Successful access with correct permissions"
      ]
    },
    {
      "name": "Request Validation",
      "description": "Tests Zod schema validation for various request types",
      "steps": [
        "Send valid project creation request",
        "Send invalid project creation (missing required fields)",
        "Send invalid query parameters",
        "Send malformed JSON",
        "Send request with invalid data types"
      ],
      "expectedOutcomes": [
        "Valid requests succeed",
        "Invalid requests return 400 Bad Request",
        "Detailed validation error messages",
        "Field-specific error information"
      ]
    },
    {
      "name": "Rate Limiting",
      "description": "Tests Redis-backed rate limiting functionality",
      "steps": [
        "Send requests within rate limit",
        "Send rapid burst of requests",
        "Verify rate limit headers",
        "Wait for rate limit reset",
        "Verify access restored after reset"
      ],
      "expectedOutcomes": [
        "Normal requests succeed",
        "Excess requests return 429 Too Many Requests",
        "Rate limit headers show remaining requests",
        "Access restored after reset period"
      ]
    },
    {
      "name": "Circuit Breaker",
      "description": "Tests circuit breaker pattern with failing services",
      "steps": [
        "Send requests to healthy service",
        "Send requests to failing service",
        "Observe circuit breaker opening",
        "Verify fast-fail responses",
        "Wait for circuit breaker reset",
        "Test half-open state"
      ],
      "expectedOutcomes": [
        "Healthy services respond normally",
        "Circuit opens after failure threshold",
        "Fast-fail responses when circuit open",
        "Circuit attempts recovery after timeout"
      ]
    },
    {
      "name": "Error Handling",
      "description": "Tests standardized error responses and logging",
      "steps": [
        "Request non-existent endpoint (404)",
        "Use wrong HTTP method (405)",
        "Send malformed request (400)",
        "Trigger server error (500)",
        "Verify error response format"
      ],
      "expectedOutcomes": [
        "Consistent error response format",
        "Correlation IDs in error responses",
        "Appropriate HTTP status codes",
        "Helpful error messages",
        "No sensitive data in error responses"
      ]
    },
    {
      "name": "Webhook Processing",
      "description": "Tests webhook endpoint handling",
      "steps": [
        "Send GitHub push webhook",
        "Send GitHub pull request webhook",
        "Send invalid webhook payload",
        "Verify webhook processing",
        "Check triggered actions"
      ],
      "expectedOutcomes": [
        "Valid webhooks processed successfully",
        "Invalid webhooks rejected appropriately",
        "Webhook events trigger correct actions",
        "Proper logging of webhook events"
      ]
    },
    {
      "name": "Performance & Monitoring",
      "description": "Tests performance characteristics and monitoring",
      "steps": [
        "Measure response times for various endpoints",
        "Check correlation ID propagation",
        "Verify structured logging",
        "Test health check endpoint",
        "Monitor resource usage"
      ],
      "expectedOutcomes": [
        "Response times under 50ms for routing",
        "Correlation IDs in all logs",
        "Structured JSON log format",
        "Health check shows service status",
        "Memory usage within limits"
      ]
    }
  ],
