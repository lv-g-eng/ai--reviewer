# Example Terraform Variables Configuration
# Copy this file to terraform.tfvars and customize for your environment
# NEVER commit terraform.tfvars to version control!

# General Configuration
aws_region   = "us-east-1"
project_name = "ai-code-reviewer"
environment  = "staging"

# VPC Configuration
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]
enable_vpc_flow_logs = true

# Compute Configuration
instance_type      = "t3.large"
min_instances      = 2
max_instances      = 10
desired_instances  = 2

# Database Configuration
db_instance_class         = "db.t3.large"
db_name                   = "ai_code_reviewer"
db_username               = "dbadmin"
db_password               = "CHANGE_ME_STRONG_PASSWORD"  # Use AWS Secrets Manager in production
db_backup_retention_days  = 7
db_multi_az               = true

# ElastiCache Configuration
redis_node_type        = "cache.t3.small"
redis_num_cache_nodes  = 2
redis_multi_az         = true
redis_auth_token       = ""  # Optional: 16-128 character auth token for Redis, leave empty to disable

# Neo4j Configuration
neo4j_connection_uri = "neo4j+s://xxxxx.databases.neo4j.io"
neo4j_username       = "neo4j"
neo4j_password       = "CHANGE_ME_STRONG_PASSWORD"  # Use AWS Secrets Manager in production

# Security Configuration
allowed_cidr_blocks = ["0.0.0.0/0"]  # Restrict this in production
ssl_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxx"

# WAF Configuration
enable_waf            = true
waf_rate_limit        = 2000  # Requests per 5 minutes per IP
waf_blocked_countries = []    # Optional: ["CN", "RU"] to block specific countries

# Monitoring Configuration
enable_detailed_monitoring = true
log_retention_days         = 30

# Additional Tags
tags = {
  Team        = "DevOps"
  CostCenter  = "Engineering"
  Compliance  = "ISO-25010"
}
